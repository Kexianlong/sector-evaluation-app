/* ==================== 标签文字 ==================== */
.tab-bar-label {
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.3px;
  line-height: 1.3;
  text-align: center;
  margin-top: 2px;
  /* 文字颜色过渡加速 */
  transition: color 0.1s ease, font-weight 0.1s ease;
}

.tab-bar-label-active {
  color: var(--accent-blue, #2563eb);
  font-weight: 600;
}
