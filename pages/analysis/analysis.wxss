/* pages/analysis/analysis.wxss */

/* ==================== 待关注学员 ==================== */
.attention-student-row {
  display: flex;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid var(--border-subtle);
}
.attention-student-row:last-child {
  border-bottom: none;
}
.attention-student-icon {
  font-size: 16px;
  margin-right: 8px;
  flex-shrink: 0;
}
.attention-student-info {
  flex: 1;
}
.attention-student-name {
  font-size: 13px;
  color: var(--text-primary);
  font-weight: 600;
  display: block;
}
.attention-student-reason {
  font-size: 11px;
  color: var(--text-muted);
  display: block;
  margin-top: 2px;
}

/* ==================== 分析结果明细 ==================== */
.analysis-detail-item {
  padding: 16px;
  margin-bottom: 12px;
  border-radius: 8px;
  background: var(--bg-secondary, #132238);
  border: 1px solid var(--border-color, #1e3a5f);
}

.analysis-detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.analysis-detail-info {
  flex: 1;
  min-width: 0;
}

.analysis-detail-name-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.analysis-rank-badge {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 700;
  flex-shrink: 0;
  background: var(--bg-tertiary, #1a2d45);
  color: var(--text-muted, #4a5d75);
}

.analysis-rank-1 {
  background: linear-gradient(135deg, #ffd700, #f0a500);
  color: #1a1a1a;
}

.analysis-rank-2 {
  background: linear-gradient(135deg, #c0c0c0, #9e9e9e);
  color: #1a1a1a;
}

.analysis-rank-3 {
  background: linear-gradient(135deg, #cd7f32, #a0522d);
  color: #fff;
}

.analysis-trend-icon {
  font-size: 14px;
  font-weight: 700;
  flex-shrink: 0;
}

.trend-up {
  color: #00d26a;
}

.trend-down {
  color: #ff4d4f;
}

.trend-stable {
  color: var(--text-muted, #4a5d75);
}

.analysis-detail-score {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4px;
}

.analysis-gap-row {
  display: flex;
  align-items: center;
  gap: 6px;
}

.analysis-gap {
  font-size: 11px;
  font-weight: 600;
  font-family: monospace;
}

.gap-positive {
  color: #00d26a;
}

.gap-negative {
  color: #ff4d4f;
}

.analysis-detail-grade {
  font-size: 11px;
  color: var(--text-muted, #4a5d75);
}

.analysis-detail-indicators {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.analysis-indicator-row {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 12px;
}

.analysis-indicator-name {
  width: 80px;
  flex-shrink: 0;
  color: var(--text-secondary, #8a9bb0);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.analysis-indicator-bar-wrap {
  flex: 1;
  height: 6px;
  background: var(--bg-tertiary, #1a2d45);
  border-radius: 3px;
  overflow: hidden;
}

.analysis-indicator-bar {
  height: 100%;
  border-radius: 3px;
  transition: width 0.4s ease;
}

.analysis-indicator-value {
  width: 48px;
  flex-shrink: 0;
  text-align: right;
  font-family: monospace;
  font-size: 11px;
}

.analysis-indicator-gap {
  width: 40px;
  flex-shrink: 0;
  text-align: right;
  font-size: 10px;
  font-weight: 600;
  font-family: monospace;
}

/* ==================== 优劣势标签 ==================== */
.analysis-sw-section {
  display: flex;
  flex-direction: column;
  gap: 6px;
  padding: 8px 0;
  margin-bottom: 8px;
  border-top: 1px solid var(--bg-tertiary, #1a2d45);
  border-bottom: 1px solid var(--bg-tertiary, #1a2d45);
}

.analysis-sw-row {
  display: flex;
  align-items: flex-start;
  gap: 8px;
}

.analysis-sw-label {
  font-size: 11px;
  font-weight: 600;
  padding: 2px 6px;
  border-radius: 3px;
  flex-shrink: 0;
  min-width: 40px;
  text-align: center;
}

.sw-strength {
  background: rgba(0, 210, 106, 0.15);
  color: #00d26a;
}

.sw-weakness {
  background: rgba(255, 77, 79, 0.15);
  color: #ff4d4f;
}

.analysis-sw-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
}

.analysis-sw-tag {
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 4px;
}

.tag-strength {
  background: rgba(0, 210, 106, 0.08);
  color: #00d26a;
  border: 1px solid rgba(0, 210, 106, 0.2);
}

.tag-weakness {
  background: rgba(255, 77, 79, 0.08);
  color: #ff4d4f;
  border: 1px solid rgba(255, 77, 79, 0.2);
}

/* ==================== 总体统计摘要 ==================== */
.summary-stats-card {
  margin-bottom: 12px;
}

.summary-stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}

.summary-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10px 4px;
  background: var(--bg-tertiary, #1a2d45);
  border-radius: 8px;
}

.summary-stat-value {
  font-size: 18px;
  font-weight: 700;
  color: var(--text-primary, #e8ecf1);
  font-family: monospace;
}

.summary-stat-high {
  color: #00d26a;
}

.summary-stat-low {
  color: #ff4d4f;
}

.summary-stat-label {
  font-size: 10px;
  color: var(--text-muted, #4a5d75);
  margin-top: 2px;
}

/* ==================== 指标统计行 ==================== */
.indicator-stats-row {
  display: flex;
  gap: 8px;
  padding: 8px 0;
  margin-bottom: 8px;
  border-top: 1px solid var(--bg-tertiary, #1a2d45);
  border-bottom: 1px solid var(--bg-tertiary, #1a2d45);
}

.indicator-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}

.indicator-stat-label {
  font-size: 10px;
  color: var(--text-muted, #4a5d75);
}

.indicator-stat-value {
  font-size: 13px;
  font-weight: 600;
  color: var(--text-primary, #e8ecf1);
  font-family: monospace;
}

.stat-high {
  color: #00d26a;
}

.stat-low {
  color: #ff4d4f;
}

/* ==================== 筛选条件网格 ==================== */
.manager-analysis-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}

.manager-analysis-field {
  display: flex;
  flex-direction: column;
}

/* ==================== 图表切换按钮 ==================== */
.trend-viz-controls {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 20px;
}

.trend-viz-group {
  display: flex;
  gap: 6px;
}

.trend-viz-btn {
  padding: 6px 12px;
  border-radius: 6px;
  font-size: 12px;
  background: var(--bg-primary, #0f1d30);
  color: var(--text-secondary, #8a9bb0);
  border: 1px solid var(--border-color, #1e3a5f);
  transition: all 0.2s;
  min-height: 32px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.trend-viz-btn.active {
  background: rgba(37, 99, 235, 0.18);
  color: #93c5fd;
  border-color: var(--accent-blue, #2563eb);
}

.trend-viz-btn:active {
  opacity: 0.85;
}

/* ==================== 图表区域 ==================== */
.trend-visual-card {
  position: relative;
}

.trend-viz-note {
  color: var(--text-secondary, #8a9bb0);
  font-size: 12px;
  margin-bottom: 10px;
}

.trend-chart-legend {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 10px;
  margin-top: 10px;
}

.trend-legend-item {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 11px;
  color: var(--text-secondary, #8a9bb0);
}

.trend-legend-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
}

/* ==================== Canvas 工具提示 ==================== */
.canvas-tooltip {
  position: absolute;
  background: rgba(19, 34, 56, 0.96);
  border: 1px solid var(--border-color, #1e3a5f);
  border-radius: 6px;
  padding: 6px 10px;
  font-size: 11px;
  color: var(--text-primary, #e8ecf1);
  pointer-events: none;
  z-index: 10;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
}

/* ==================== 芯片选择器 ==================== */
.analysis-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.analysis-chip {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 4px 10px;
  background: var(--bg-tertiary, #1a2d45);
  border: 1px solid var(--border-color, #1e3a5f);
  border-radius: 4px;
  font-size: 12px;
  color: var(--text-primary, #e8ecf1);
}

.analysis-chip-remove {
  color: var(--alert-red, #ff4d4f);
  font-size: 11px;
  padding: 2px 6px;
  min-height: 24px;
  min-width: 24px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.analysis-trigger {
  padding: 6px 14px;
  background: rgba(37, 99, 235, 0.08);
  color: #60a5fa;
  border: 1px dashed rgba(37, 99, 235, 0.4);
  border-radius: 6px;
  font-size: 12px;
  min-height: 32px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.analysis-trigger:active {
  opacity: 0.85;
}

.analysis-tip {
  color: var(--text-muted, #4a5d75);
  font-size: 11px;
  margin-top: 6px;
  line-height: 1.5;
}

/* 筛选字段网格增强 */
.manager-analysis-grid .form-input {
  min-height: 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 12px;
}

/* ==================== 弹窗（与全局对齐） ==================== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 10001;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 82%;
  max-width: 340px;
  background: var(--bg-secondary, #132238);
  border-radius: 12px;
  border: 1px solid var(--border-color, #1e3a5f);
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 16px;
  border-bottom: 1px solid var(--bg-tertiary, #1a2d45);
}

.modal-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary, #e8ecf1);
}

.modal-close {
  color: var(--text-muted, #4a5d75);
  font-size: 13px;
  padding: 4px 8px;
  min-height: 32px;
  min-width: 32px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.modal-body {
  max-height: 320px;
}

.modal-item {
  padding: 12px 16px;
  border-bottom: 1px solid var(--bg-tertiary, #1a2d45);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.modal-item-main {
  flex: 1;
  min-width: 0;
}

.modal-item-text {
  color: var(--text-primary, #e8ecf1);
  font-size: 14px;
}

.modal-item-sub {
  color: var(--text-muted, #4a5d75);
  font-size: 11px;
  margin-top: 2px;
}

.modal-checkbox {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  border: 2px solid var(--text-muted, #4a5d75);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.modal-checkbox-checked {
  border-color: var(--radar-green, #00d26a);
}

.modal-checkbox-inner {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: var(--radar-green, #00d26a);
}

.modal-footer {
  padding: 12px 16px;
  border-top: 1px solid var(--bg-tertiary, #1a2d45);
}

/* ==================== 指标详情面板 ==================== */
.indicator-detail-panel {
  background: var(--bg-secondary, #132238);
  border: 1px solid var(--border-color, #1e3a5f);
  border-radius: 12px;
  padding: 16px;
  margin: 12px 0;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

.indicator-detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--bg-tertiary, #1a2d45);
}

.indicator-detail-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary, #e8ecf1);
  flex: 1;
}

.indicator-detail-score {
  font-size: 20px;
  font-weight: 700;
  font-family: monospace;
  margin: 0 12px;
}

.indicator-detail-close {
  color: var(--text-muted, #4a5d75);
  font-size: 18px;
  padding: 4px 8px;
  min-height: 32px;
  min-width: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.indicator-detail-desc {
  font-size: 13px;
  color: var(--text-secondary, #8a9bb0);
  line-height: 1.6;
  margin-bottom: 12px;
  padding: 10px 12px;
  background: var(--bg-primary, #0f1d30);
  border-radius: 8px;
  border-left: 3px solid var(--accent-blue, #2563eb);
}

.indicator-detail-meta {
  font-size: 12px;
  color: var(--text-muted, #4a5d75);
  margin-bottom: 16px;
}

.indicator-history-trend {
  margin-top: 12px;
}

.indicator-history-label {
  font-size: 12px;
  font-weight: 600;
  color: var(--text-secondary, #8a9bb0);
  margin-bottom: 8px;
}

.indicator-history-scroll {
  white-space: nowrap;
}

.indicator-history-bars {
  display: flex;
  gap: 8px;
  padding: 4px 0;
}

.indicator-history-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 48px;
}

.indicator-history-bar-wrap {
  width: 32px;
  height: 80px;
  background: var(--bg-tertiary, #1a2d45);
  border-radius: 4px;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
}

.indicator-history-bar {
  width: 100%;
  border-radius: 4px 4px 0 0;
  transition: height 0.3s ease;
  min-height: 4px;
}

.indicator-history-date {
  font-size: 10px;
  color: var(--text-muted, #4a5d75);
  margin-top: 6px;
}

.indicator-history-score {
  font-size: 11px;
  font-weight: 600;
  font-family: monospace;
  color: var(--text-primary, #e8ecf1);
  margin-top: 2px;
}
