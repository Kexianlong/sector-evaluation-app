<view class="login-page">
  <!-- 顶部航空标识区 -->
  <view class="login-header">
    <image class="login-logo-img" src="/images/logo.png" mode="aspectFit" />
    <view class="login-title">扇区能力评估系统</view>
    <view class="login-en-title">SECTOR COMPETENCY ASSESSMENT</view>
    <view class="login-title-divider"></view>
    <view class="login-subtitle">空中交通管制员 · 能力考核与评估平台</view>
  </view>

  <view class="login-form">
    <!-- 账号 -->
    <view class="login-form-group">
      <view class="login-form-label">
        <text class="status-dot blue"></text>
        账号
      </view>
      <input class="login-input" value="{{username}}" bindinput="onInputUsername" placeholder="请输入用户名" placeholder-class="login-placeholder" disabled="{{showPasswordModal}}" />
    </view>

    <!-- 密码 -->
    <view class="login-form-group">
      <view class="login-form-label">
        <text class="status-dot blue"></text>
        密码
      </view>
      <input class="login-input" value="{{password}}" bindinput="onInputPassword" password placeholder="请输入密码" placeholder-class="login-placeholder" disabled="{{showPasswordModal}}" />
    </view>

    <!-- 岗位提示 -->
    <view class="login-role-hint">
      岗位由系统账号自动识别，无需手动选择角色。
    </view>

    <!-- 登录按钮 -->
    <view class="login-btn login-btn-primary" bindtap="handleLogin" disabled="{{loading || showPasswordModal}}">
      {{loading ? '登录中...' : '进入系统'}}
    </view>

    <view wx:if="{{error}}" class="login-error-msg">{{error}}</view>
  </view>

  <!-- 底部版权 -->
  <view class="login-footer">
    <text>Air Traffic Control Training System v1.0</text>
  </view>

  <!-- 修改密码提醒弹窗 -->
  <view wx:if="{{showPasswordModal}}" class="modal-mask">
    <view class="modal-content">
      <!-- 提醒页面 -->
      <block wx:if="{{!showPasswordForm}}">
        <view style="font-size: 32px; text-align: center; margin-bottom: 12px;">🔒</view>
        <view class="modal-title">请修改默认密码</view>
        <view class="modal-desc">您当前使用的是系统默认密码，为保障账号安全，建议立即修改密码。</view>
        <view class="modal-actions">
          <view class="login-btn login-btn-primary modal-btn" bindtap="handleShowPasswordForm">立即修改</view>
          <view class="login-btn login-btn-secondary modal-btn" bindtap="handleCancelPasswordChange">稍后提醒</view>
        </view>
      </block>

      <!-- 修改密码表单 -->
      <block wx:if="{{showPasswordForm}}">
        <view class="modal-title">修改密码</view>
        <view class="login-form-group">
          <view class="login-form-label">旧密码</view>
          <input class="login-input" type="password" value="{{oldPassword}}" bindinput="onInputOldPassword" placeholder="请输入旧密码" placeholder-class="login-placeholder" />
        </view>
        <view class="login-form-group">
          <view class="login-form-label">新密码</view>
          <input class="login-input" type="password" value="{{newPassword}}" bindinput="onInputNewPassword" placeholder="新密码至少6位" placeholder-class="login-placeholder" />
        </view>
        <view class="login-form-group">
          <view class="login-form-label">确认新密码</view>
          <input class="login-input" type="password" value="{{confirmPassword}}" bindinput="onInputConfirmPassword" placeholder="再次输入新密码" placeholder-class="login-placeholder" />
        </view>
        <view wx:if="{{passwordError}}" class="login-error-msg">{{passwordError}}</view>
        <view wx:if="{{passwordSuccess}}" style="color: var(--radar-green); font-size: 13px; text-align: center; margin-bottom: 12px;">{{passwordSuccess}}</view>
        <view class="modal-actions">
          <view class="login-btn login-btn-primary modal-btn" bindtap="handleChangePassword">确认修改</view>
          <view class="login-btn login-btn-secondary modal-btn" bindtap="handleCancelPasswordChange">取消</view>
        </view>
      </block>
    </view>
  </view>

  <!-- 首次登录信息补全弹窗 -->
  <view wx:if="{{showProfileModal}}" class="modal-mask">
    <view class="modal-content" style="max-height:80vh;overflow-y:auto;">
      <view style="font-size: 32px; text-align: center; margin-bottom: 12px;">📋</view>
      <view class="modal-title">完善个人信息</view>
      <view class="modal-desc">请补充以下信息，以便系统为您提供准确服务</view>

      <!-- 头像 -->
      <view class="login-form-group">
        <view class="login-form-label">头像</view>
        <view style="display:flex;align-items:center;gap:12px;" bindtap="chooseProfileAvatar">
          <image style="width:56px;height:56px;border-radius:50%;border:2px solid var(--border-color,#1e3a5f);background:var(--bg-tertiary,#1a2d45);" src="{{profilePhotoUrl || 'data:image/svg+xml;base64,'}}" mode="aspectFill" />
          <text style="font-size:12px;color:var(--text-secondary);">点击上传头像</text>
        </view>
      </view>

      <!-- 手机号 -->
      <view class="login-form-group">
        <view class="login-form-label">手机号码 <text style="color:var(--alert-red);">*</text></view>
        <view style="display:flex;gap:8px;">
          <input class="login-input" style="flex:1;" value="{{profilePhone}}" bindinput="onProfilePhoneInput" placeholder="请输入手机号" type="number" maxlength="11" />
          <button class="login-btn login-btn-secondary" style="width:auto;min-width:100px;font-size:12px;margin:0;padding:0 12px;" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">微信授权</button>
        </view>
      </view>

      <view class="login-form-group">
        <view class="login-form-label">性别 <text style="color:var(--alert-red);">*</text></view>
        <picker bindchange="onProfileGenderChange" value="{{profileGender === '女' ? 1 : 0}}" range="{{['男', '女']}}">
          <view class="login-input" style="display:flex;align-items:center;justify-content:space-between;">
            <text style="color:{{profileGender ? '#e2e8f0' : '#475569'}};">{{profileGender || '请选择性别'}}</text>
            <text style="color:#475569;">▼</text>
          </view>
        </picker>
      </view>

      <view class="login-form-group">
        <view class="login-form-label">出生日期 <text style="color:var(--alert-red);">*</text></view>
        <picker mode="date" value="{{profileBirthDate}}" bindchange="onProfileBirthDateChange">
          <view class="login-input" style="display:flex;align-items:center;justify-content:space-between;">
            <text style="color:{{profileBirthDate ? '#e2e8f0' : '#475569'}};">{{profileBirthDate || '请选择出生日期'}}</text>
            <text style="color:#475569;">▼</text>
          </view>
        </picker>
      </view>

      <view wx:if="{{profileIsStudent}}" class="login-form-group">
        <view class="login-form-label">进组时间 <text style="color:var(--alert-red);">*</text></view>
        <picker mode="date" value="{{profileGroupEntryDate}}" bindchange="onProfileGroupEntryDateChange">
          <view class="login-input" style="display:flex;align-items:center;justify-content:space-between;">
            <text style="color:{{profileGroupEntryDate ? '#e2e8f0' : '#475569'}};">{{profileGroupEntryDate || '请选择进组时间'}}</text>
            <text style="color:#475569;">▼</text>
          </view>
        </picker>
      </view>

      <!-- ICAO日期 -->
      <view class="login-form-group">
        <view class="login-form-label">ICAO获取时间 <text style="color:var(--text-muted);font-size:11px;margin-left:4px;">（选填，3年有效期）</text></view>
        <picker mode="date" value="{{profileIcaoDate}}" bindchange="onProfileIcaoDateChange">
          <view class="login-input" style="display:flex;align-items:center;justify-content:space-between;">
            <text style="color:{{profileIcaoDate ? '#e2e8f0' : '#475569'}};">{{profileIcaoDate || '请选择ICAO获取时间'}}</text>
            <text style="color:#475569;">▼</text>
          </view>
        </picker>
      </view>

      <!-- 体检日期 -->
      <view class="login-form-group">
        <view class="login-form-label">体检合格证获取时间 <text style="color:var(--text-muted);font-size:11px;margin-left:4px;">（选填，2年有效期）</text></view>
        <picker mode="date" value="{{profileMedicalDate}}" bindchange="onProfileMedicalDateChange">
          <view class="login-input" style="display:flex;align-items:center;justify-content:space-between;">
            <text style="color:{{profileMedicalDate ? '#e2e8f0' : '#475569'}};">{{profileMedicalDate || '请选择体检日期'}}</text>
            <text style="color:#475569;">▼</text>
          </view>
        </picker>
      </view>

      <!-- 责任关系 -->
      <view wx:if="{{profileIsInstructor && instructorStudentList.length > 0}}" class="login-form-group">
        <view class="login-form-label">责任学员</view>
        <picker bindchange="onProfileResponsibleStudentsChange" value="{{profileResponsibleStudentIndex}}" range="{{instructorStudentList}}">
          <view class="login-input" style="display:flex;align-items:center;justify-content:space-between;">
            <text style="color:{{profileResponsibleStudentsLabel ? '#e2e8f0' : '#475569'}};">{{profileResponsibleStudentsLabel || '请选择责任学员'}}</text>
            <text style="color:#475569;">▼</text>
          </view>
        </picker>
        <view wx:if="{{profileResponsibleStudents.length > 0}}" style="display:flex;flex-wrap:wrap;gap:6px;margin-top:8px;">
          <view wx:for="{{profileResponsibleStudentsInfo}}" wx:key="userId" style="display:flex;align-items:center;gap:4px;font-size:12px;color:var(--accent-blue);background:rgba(59,130,246,0.1);border:1px solid rgba(59,130,246,0.3);padding:2px 8px;border-radius:4px;">
            <text>{{item.name}}</text>
            <text style="color:var(--text-muted);" bindtap="removeResponsibleStudent" data-id="{{item.userId}}">✕</text>
          </view>
        </view>
      </view>

      <view wx:if="{{profileIsStudent && studentInstructorList.length > 0}}" class="login-form-group">
        <view class="login-form-label">责任教员 <text style="color:var(--alert-red);">*</text></view>
        <picker bindchange="onProfileResponsibleInstructorChange" value="{{profileResponsibleInstructorIndex}}" range="{{studentInstructorList}}">
          <view class="login-input" style="display:flex;align-items:center;justify-content:space-between;">
            <text style="color:{{profileResponsibleInstructorLabel ? '#e2e8f0' : '#475569'}};">{{profileResponsibleInstructorLabel || '请选择责任教员'}}</text>
            <text style="color:#475569;">▼</text>
          </view>
        </picker>
      </view>

      <view wx:if="{{profileError}}" class="login-error-msg">{{profileError}}</view>

      <!-- 默认密码安全提醒 -->
      <view wx:if="{{usingDefaultPassword}}" class="login-form-group" style="background:rgba(255,170,0,0.06);border:1px solid rgba(255,170,0,0.2);border-radius:6px;padding:10px 12px;margin-top:8px;">
        <view style="font-size:12px;color:#fbbf24;line-height:1.6;">
          <text style="font-weight:600;">⚠ 安全提醒：</text>您当前使用的是系统默认密码，建议立即修改以保障账号安全。
        </view>
        <view class="login-btn login-btn-secondary modal-btn" style="margin-top:8px;height:32px;min-height:32px;font-size:12px;border-radius:4px;" bindtap="switchToPasswordModal">去修改密码</view>
      </view>

      <view class="modal-actions">
        <view class="login-btn login-btn-primary modal-btn" bindtap="handleProfileSave">保存并继续</view>
        <view class="login-btn login-btn-secondary modal-btn" bindtap="handleProfileSkip">稍后再说</view>
      </view>
    </view>
  </view>
</view>
