<view class="container">
  <!-- 学员个人信息卡片 -->
  <view class="card mygrades-profile-card" wx:if="{{!canViewAll}}">
    <view class="mygrades-profile">
      <button class="mygrades-profile-avatar-btn" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
        <image class="mygrades-profile-avatar" src="{{avatarUrl}}" mode="aspectFill" />
      </button>
      <view class="mygrades-profile-body" bindtap="goToProfile">
        <view class="mygrades-profile-top">
          <text class="mygrades-profile-name">{{userInfo.name || '未登录'}}</text>
          <text wx:if="{{roleLabel}}" class="identity-badge identity-badge-role">{{roleLabel}}</text>
          <text wx:if="{{levelLabel}}" class="identity-badge identity-badge-level">{{levelLabel}}</text>
        </view>
        <view class="mygrades-profile-meta">
          <text wx:if="{{gender}}" class="mygrades-profile-meta-item">{{gender}}</text>
          <text wx:if="{{age}}" class="mygrades-profile-meta-item">{{age}}岁</text>
          <text wx:if="{{studentLevel}}" class="mygrades-profile-meta-item">{{studentLevel}}</text>
          <text wx:if="{{groupEntryDate}}" class="mygrades-profile-meta-item">进组: {{groupEntryDate}}</text>
          <text wx:if="{{icaoExpiry}}" class="mygrades-profile-meta-item">ICAO: {{icaoExpiry}}</text>
          <text wx:if="{{medicalExpiry}}" class="mygrades-profile-meta-item">体检: {{medicalExpiry}}</text>
        </view>
      </view>
    </view>
  </view>
  <view class="manager-logout-btn" bindtap="logout" wx:if="{{!canViewAll}}">退出登录</view>

  <!-- 教员/管理视角：简洁用户信息 -->
  <view class="trend-toolbar" style="margin-bottom:12px;" wx:if="{{canViewAll}}">
    <view class="trend-user-meta" bindtap="goToProfile">
      <text class="trend-user-name">{{userInfo.name || '未登录'}}</text>
      <text wx:if="{{roleLabel}}" class="identity-badge identity-badge-role">{{roleLabel}}</text>
      <text wx:if="{{levelLabel}}" class="identity-badge identity-badge-level">{{levelLabel}}</text>
    </view>
  </view>

  <!-- 错误提示 -->
  <view wx:if="{{loadError}}" class="trend-inline-alert">
    <text>{{loadError}}</text>
    <view bindtap="retry" class="trend-retry-btn">重试</view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="trend-loading-state">数据加载中...</view>
  <view wx:if="{{loading}}" class="trend-skeleton-list" aria-hidden="true">
    <view class="trend-skeleton-row" />
    <view class="trend-skeleton-row" />
    <view class="trend-skeleton-row" />
  </view>

  <!-- 空状态 -->
  <view wx:if="{{!loading && filteredScores.length === 0 && !loadError}}" class="empty-state">
    <view class="empty-text">暂无评分记录</view>
  </view>

  <!-- 学员评分列表 -->
  <view wx:for="{{filteredScores}}" wx:for-item="stu" wx:for-index="stuIdx" wx:key="id" class="trend-student-overview fade-in">
      <!-- 扇区趋势图：直接显示 -->
    <view wx:for="{{allStudentTrendData[stu.studentId]}}" wx:for-item="trend" wx:key="sectorId" class="card sector-trend-card" style="margin-top:12px;">
      <view class="sector-trend-header">
        <text class="sector-trend-name">{{trend.sectorName}}</text>
        <text class="sector-trend-count">{{trend.scores.length}}次评分</text>
      </view>
      <view class="sector-trend-canvas-wrap">
        <canvas type="2d" id="trendCanvas_{{stu.studentId}}_{{trend.sectorId}}" class="sector-trend-canvas" style="width:100%;height:160px;" />
        <cover-view class="sector-trend-canvas-cover" bindtap="goToSectorHistory" data-student-id="{{stu.studentId}}" data-sector-id="{{trend.sectorId}}" data-student-name="{{stu.studentName}}" />
      </view>
      <view class="sector-trend-dates">
        <view wx:for="{{trend.scores}}" wx:for-item="sc" wx:key="date" class="sector-trend-date-tag" bindtap="goToRadarByScore" data-student-id="{{stu.studentId}}" data-sector-id="{{trend.sectorId}}" data-date="{{sc.date}}" data-student-name="{{stu.studentName}}">
          <text class="sector-trend-date-text">{{sc.shortDate}}</text>
          <text class="sector-trend-date-score">{{sc.totalScore}}分</text>
        </view>
      </view>
      <view class="sector-trend-summary">
        <view class="sector-trend-stat">
          <text class="stat-label">最高</text>
          <text class="stat-value stat-high">{{trend.maxScore}}</text>
        </view>
        <view class="sector-trend-stat">
          <text class="stat-label">平均</text>
          <text class="stat-value">{{trend.avgScore}}</text>
        </view>
        <view class="sector-trend-stat">
          <text class="stat-label">最低</text>
          <text class="stat-value stat-low">{{trend.minScore}}</text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 学员历史评分详情弹窗 -->
<view wx:if="{{showHistoryPopup}}" class="popup-mask" bindtap="closeHistoryPopup">
  <view class="popup-content" catchtap="preventClose">
    <view class="popup-header">
      <view class="popup-title">{{detailStudent.studentName}} 的历史评分</view>
      <view class="radar-popup-close" bindtap="closeHistoryPopup">&#x2715;</view>
    </view>

    <!-- 统计卡片 -->
    <view class="stat-grid {{detailLoading ? 'stat-grid-dim' : ''}}">
      <view class="stat-card">
        <view class="stat-value">{{detailLoading ? '—' : historyStats.count}}</view>
        <view class="stat-label">评估次数</view>
      </view>
      <view class="stat-card">
        <view class="stat-value">{{detailLoading ? '—' : historyStats.avgScore}}</view>
        <view class="stat-label">平均分</view>
      </view>
      <view class="stat-card">
        <view class="stat-value" style="font-size:14px;font-weight:600;color:var(--text-primary);">{{detailLoading ? '—' : historyStats.bestSector}}</view>
        <view class="stat-label">最佳扇区</view>
      </view>
      <view class="stat-card">
        <view class="stat-value" style="font-size:14px;font-weight:600;color:var(--amber);">{{detailLoading ? '—' : historyStats.bestGrade}}</view>
        <view class="stat-label">最高等级</view>
      </view>
    </view>

    <!-- 历史记录列表 -->
    <view class="card" style="margin-bottom:0;">
      <view class="card-title">评估历史</view>
      <view wx:if="{{detailLoading}}" class="trend-loading-state">数据加载中...</view>
      <view wx:if="{{!detailLoading && studentHistory.length === 0}}" class="empty-state empty-state-compact">
        <view class="empty-text">暂无评估记录</view>
      </view>

      <view wx:for="{{studentHistory}}" wx:key="id" class="student-history-block">
        <view class="student-history-toggle {{detailExpandedId === item.id ? 'student-history-toggle-open' : ''}}" bindtap="toggleDetailExpand" data-id="{{item.id}}">
          <view class="student-history-row-head">
            <view>
              <view class="list-item-title"><text class="sector-tag">{{item.sectorName}}</text></view>
              <view class="list-item-sub">{{item.date}}</view>
            </view>
            <text class="score-badge {{item._gradeClass}}">{{item._grade}}</text>
          </view>
          <text class="list-item-arrow">{{detailExpandedId === item.id ? '▼' : '▶'}}</text>
        </view>

        <view wx:if="{{detailExpandedId === item.id}}" class="student-history-panel">
          <view class="student-history-total-row">
            <text class="student-history-total-label">总分</text>
            <text class="student-history-total-value">{{item.total}}<text class="student-history-total-max"> / {{item.maxTotal}}</text></text>
          </view>

          <!-- 雷达图 -->
          <canvas type="2d" id="historyRadarCanvas" style="width:100%;height:220px;margin-bottom:12px;" />

          <!-- 分类得分 -->
          <view wx:for="{{item._scorePairs}}" wx:for-item="sp" wx:key="name" class="radar-score-row">
            <view class="radar-score-left">
              <view class="radar-score-name">{{sp.name}}</view>
            </view>
            <view class="radar-score-right">
              <view class="progress-bar radar-score-progress">
                <view class="progress-fill" style="width:{{sp.maxScore > 0 ? Math.round((sp.score/sp.maxScore)*100) : 0}}%;background:{{sp.score*100/sp.maxScore>=90?'#00d26a':sp.score*100/sp.maxScore>=75?'#ffaa00':'#60a5fa'}};" />
              </view>
              <text class="score-badge radar-score-value-badge score-pass">{{sp.score}}</text>
            </view>
          </view>

          <!-- 扣分项 -->
          <view wx:if="{{item._deductItems.length > 0}}" style="margin-top:8px;">
            <view wx:for="{{item._deductItems}}" wx:for-item="d" wx:key="itemId" class="trend-overview-deduct-item mygrades-deduct-item" bindtap="toggleDetailDeductExpand" data-key="{{item.id}}_{{d.itemId}}">
              <view style="display:flex;justify-content:space-between;align-items:center;">
                <view>
                  <view class="trend-overview-deduct-name">{{d.itemName}}</view>
                  <view class="trend-overview-deduct-meta">扣 {{d.deductVal}} 分（{{d.score}}/{{d.maxScore}}）</view>
                </view>
                <text style="font-size:11px;color:var(--text-muted);">{{detailExpandedDeductId === item.id + '_' + d.itemId ? '▼' : '▶'}}</text>
              </view>
              <view wx:if="{{detailExpandedDeductId === item.id + '_' + d.itemId && d.reason}}" class="trend-overview-deduct-reason mygrades-deduct-reason">{{d.reason}}</view>
              <view wx:if="{{detailExpandedDeductId === item.id + '_' + d.itemId && !d.reason}}" class="trend-overview-deduct-empty">未填写扣分原因</view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 分类详情弹窗（点击分类得分条触发） -->
<view wx:if="{{showCategoryPopup}}" class="popup-mask" bindtap="hideCategoryPopup">
  <view class="popup-content" catchtap="preventClose">
    <view class="popup-header">
      <view class="popup-title">{{categoryPopupTitle}}</view>
      <view class="radar-popup-close" bindtap="hideCategoryPopup">&#x2715;</view>
    </view>

    <!-- 历史趋势 -->
    <view wx:if="{{categoryPopupTrend.length >= 2}}" class="radar-cat-trend-section">
      <view class="radar-cat-trend-title">历史趋势（点击柱子查看该次评分详情）</view>
      <view class="radar-cat-trend-row">
        <view wx:for="{{categoryPopupTrend}}" wx:key="date" class="radar-cat-trend-item {{categoryPopupIndex === index ? 'radar-cat-trend-item--active' : ''}}" bindtap="onCategoryTrendTap" data-index="{{index}}">
          <view class="radar-cat-trend-bar-wrap">
            <view class="radar-cat-trend-bar" style="height:{{item.maxScore > 0 ? (item.score / item.maxScore * 100) : 0}}%;background:{{item.score >= item.maxScore * 0.9 ? 'var(--radar-green)' : item.score >= item.maxScore * 0.75 ? 'var(--amber)' : 'var(--alert-red)'}};"></view>
          </view>
          <text class="radar-cat-trend-score" style="color:{{item.score >= item.maxScore * 0.9 ? 'var(--radar-green)' : item.score >= item.maxScore * 0.75 ? 'var(--amber)' : 'var(--alert-red)'}};">{{item.score}}</text>
          <text class="radar-cat-trend-date">{{item.date}}</text>
        </view>
      </view>
    </view>

    <!-- 单次评分信息 -->
    <view wx:if="{{categoryPopupTrend.length === 1}}" class="radar-cat-trend-detail">
      <view class="radar-cat-trend-detail-row">
        <text class="radar-cat-trend-detail-label">日期</text>
        <text class="radar-cat-trend-detail-value">{{categoryPopupTrend[0].fullDate}}</text>
      </view>
      <view class="radar-cat-trend-detail-row">
        <text class="radar-cat-trend-detail-label">得分</text>
        <text class="radar-cat-trend-detail-value" style="color:{{categoryPopupTrend[0].score >= categoryPopupTrend[0].maxScore * 0.9 ? 'var(--radar-green)' : categoryPopupTrend[0].score >= categoryPopupTrend[0].maxScore * 0.75 ? 'var(--amber)' : 'var(--alert-red)'}};">{{categoryPopupTrend[0].score}} / {{categoryPopupTrend[0].maxScore}}</text>
      </view>
      <view class="radar-cat-trend-detail-row">
        <text class="radar-cat-trend-detail-label">得分率</text>
        <text class="radar-cat-trend-detail-value">{{categoryPopupRate}}%</text>
      </view>
    </view>

    <!-- 选中记录信息 -->
    <view wx:if="{{categoryPopupTrend.length >= 2 && categoryPopupIndex >= 0 && categoryPopupRecord}}" class="radar-cat-trend-detail">
      <view class="radar-cat-trend-detail-row">
        <text class="radar-cat-trend-detail-label">日期</text>
        <text class="radar-cat-trend-detail-value">{{categoryPopupRecord.date}}</text>
      </view>
      <view class="radar-cat-trend-detail-row">
        <text class="radar-cat-trend-detail-label">得分</text>
        <text class="radar-cat-trend-detail-value" style="color:{{categoryPopupTrend[categoryPopupIndex].score >= categoryPopupTrend[categoryPopupIndex].maxScore * 0.9 ? 'var(--radar-green)' : categoryPopupTrend[categoryPopupIndex].score >= categoryPopupTrend[categoryPopupIndex].maxScore * 0.75 ? 'var(--amber)' : 'var(--alert-red)'}};">{{categoryPopupTrend[categoryPopupIndex].score}} / {{categoryPopupTrend[categoryPopupIndex].maxScore}}</text>
      </view>
      <view class="radar-cat-trend-detail-row">
        <text class="radar-cat-trend-detail-label">得分率</text>
        <text class="radar-cat-trend-detail-value">{{categoryPopupRate}}%</text>
      </view>
    </view>

    <!-- 扣分项列表 -->
    <view wx:if="{{categoryPopupItems.length === 0}}" class="empty-state" style="padding:20px;">
      <view class="empty-text">暂无子项配置数据</view>
    </view>
    <view wx:for="{{categoryPopupItems}}" wx:key="deductKey" class="list-item {{item.isDeducted ? 'radar-detail-item--danger' : ''}}">
      <view class="radar-detail-row">
        <view class="radar-detail-left">
          <view class="radar-detail-name">{{item.name}}</view>
          <view wx:if="{{item.deductionTemplate && !item.isDeducted}}" class="radar-detail-desc">{{item.deductionTemplate}}</view>
          <view wx:if="{{item.isDeducted}}" class="radar-detail-deduct">扣 {{item.maxScore - item.score}} 分（{{item.score}}/{{item.maxScore}}）</view>
        </view>
        <view class="radar-detail-right">
          <text wx:if="{{item.hasScore}}" class="radar-detail-score" style="{{item.isDeducted ? 'color:var(--alert-red);' : 'color:var(--radar-green);'}}">{{item.score}} / {{item.maxScore}}</text>
          <text wx:else class="radar-detail-score" style="color:var(--text-muted);">满分 {{item.maxScore || 0}}</text>
        </view>
      </view>
      <view wx:if="{{item.deductionReason}}" class="radar-detail-reason"><text style="color:var(--danger);font-weight:700;margin-right:4px;">[扣分说明]</text>{{item.deductionReason}}</view>
    </view>
  </view>
</view>
