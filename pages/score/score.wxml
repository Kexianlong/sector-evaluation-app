<view class="container">
  <!-- 教员个人信息卡片 -->
  <view class="card mygrades-profile-card">
    <view class="mygrades-profile">
      <button class="mygrades-profile-avatar-btn" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
        <image class="mygrades-profile-avatar" src="{{avatarUrl}}" mode="aspectFill" />
      </button>
      <view class="mygrades-profile-body" bindtap="goToProfile">
        <view class="mygrades-profile-top">
          <text class="mygrades-profile-name">{{userInfo.name || '未登录'}}</text>
          <text wx:if="{{roleLabel}}" class="identity-badge identity-badge-role">{{roleLabel}}</text>
          <text wx:if="{{levelLabel}}" class="identity-badge identity-badge-level">{{levelLabel}}</text>
        </view>
        <view class="mygrades-profile-meta">
          <text wx:if="{{gender}}" class="mygrades-profile-meta-item">{{gender}}</text>
          <text wx:if="{{age}}" class="mygrades-profile-meta-item">{{age}}岁</text>
          <text wx:if="{{groupEntryDate}}" class="mygrades-profile-meta-item">进组: {{groupEntryDate}}</text>
          <text wx:if="{{icaoExpiry}}" class="mygrades-profile-meta-item">ICAO: {{icaoExpiry}}</text>
          <text wx:if="{{medicalExpiry}}" class="mygrades-profile-meta-item">体检: {{medicalExpiry}}</text>
        </view>
      </view>
    </view>
  </view>
  <view class="manager-logout-btn" bindtap="logout">退出登录</view>

  <!-- ========== 开始评分入口 ========== -->
  <block wx:if="{{canScore && !isManager}}">
    <view class="card score-start-card" bindtap="startScoreFlow">
      <view class="score-start-content">
        <view class="score-start-icon">📝</view>
        <view class="score-start-text">
          <view class="score-start-title">开始评分</view>
          <view class="score-start-desc">选择学员与扇区，分步完成评分</view>
        </view>
        <view class="score-start-arrow">▶</view>
      </view>
    </view>

    <!-- 历史参考面板 -->
    <view class="card mb-12" wx:if="{{selectedStudent && historyRefData}}">
      <view class="card-title-bar" bindtap="toggleHistoryRef">
        <text class="card-title">📊 历史参考</text>
        <text class="score-category-toggle" style="{{showHistoryRef ? 'transform:rotate(180deg);' : ''}}">▼</text>
      </view>
      <view wx:if="{{showHistoryRef}}" class="fade-transition">
        <view class="flex-between mb-8">
          <text class="text-secondary text-13">近3次评分</text>
          <text class="text-primary fw-600">{{historyRefData.recentScores}}</text>
        </view>
        <view class="flex-between mb-8">
          <text class="text-secondary text-13">平均分</text>
          <text class="text-primary fw-600">{{historyRefData.avgScore}}分</text>
        </view>
        <view class="flex-between" wx:if="{{historyRefData.weakCategory}}">
          <text class="text-secondary text-13">上次薄弱项</text>
          <text class="text-amber fw-600">{{historyRefData.weakCategory}}</text>
        </view>
      </view>
    </view>

    <!-- 历史评分 -->
    <view class="card mb-12">
      <view class="section-title section-title-bar">历史评分</view>
      <view class="caption-text mb-10">
        当前筛选：{{selectedStudentName || '全部学员'}} · {{sectorConfigNames[sector] || sector}}
      </view>
      <view wx:if="{{editingScoreId}}" class="trend-inline-alert history-alert">
        <text>当前正在修改历史评分（仅可修改一次）</text>
        <!-- dynamic: color -->
        <text bindtap="cancelEdit" class="btn-text-sm text-alert">取消修改</text>
      </view>
      <view wx:if="{{historyLoading}}" class="trend-loading-state">历史评分加载中...</view>
      <!-- dynamic: background, border-color, color -->
      <view wx:if="{{historyError}}" class="trend-inline-alert" style="background:rgba(255,77,79,0.08);border-color:rgba(255,77,79,0.2);color:var(--alert-red);">
        <text>{{historyError}}</text>
        <!-- dynamic: border -->
        <text bindtap="loadHistory" class="btn-text-sm rounded-4" style="border:1px solid rgba(255,77,79,0.3);">重试</text>
      </view>
      <view wx:if="{{!historyLoading && scoreHistory.length === 0 && !historyError}}" class="empty-state empty-state-compact">
        <text class="empty-text">暂无历史评分记录</text>
      </view>
      <view wx:for="{{scoreHistory}}" wx:for-index="hIdx" wx:for-item="hItem" wx:key="scoreId" wx:if="{{hIdx < 8}}" class="score-history-row">
        <view>
          <view class="item-title history-date">{{hItem.date}} · {{hItem.studentName}}</view>
          <view class="caption-text history-meta">总分 {{hItem.totalScore}} · {{hItem.grade}} · 已修改 {{hItem.editCount || 0}} / 1 次</view>
        </view>
        <!-- dynamic: background, color, border -->
        <view bindtap="handleStartEdit" data-score-id="{{hItem.scoreId}}" class="tag-btn" style="background:{{(hItem.instructorId === userInfo.userId && (hItem.editCount || 0) < 1) ? 'rgba(37,99,235,0.12)' : 'var(--bg-tertiary)'}};color:{{(hItem.instructorId === userInfo.userId && (hItem.editCount || 0) < 1) ? 'var(--accent-blue)' : 'var(--text-muted)'}};border:1px solid {{(hItem.instructorId === userInfo.userId && (hItem.editCount || 0) < 1) ? 'rgba(37,99,235,0.3)' : 'var(--bg-tertiary)'}};">
          {{(hItem.instructorId === userInfo.userId && (hItem.editCount || 0) < 1) ? '修改评分' : '不可修改'}}
        </view>
      </view>
    </view>

    <view class="spacer-20"></view>
  </block>

  <!-- ========== 管理角色：数据分析 ========== -->
  <block wx:if="{{isManager}}">
    <!-- 筛选面板 -->
    <view class="card mb-12">
      <view class="card-title card-title-bar flex-between" bindtap="toggleFilterPanel">
        <text>数据筛选</text>
        <text class="text-12 text-muted ml-auto">{{showFilterPanel ? '▲' : '▼'}}</text>
      </view>

      <block wx:if="{{showFilterPanel}}">
        <!-- 学员选择 -->
        <view class="filter-section-lg">
          <view class="label">学员选择（最多6人）</view>
          <view class="flex-wrap-gap8 mb-6 min-h-32">
            <view wx:for="{{analysisConfig.selectedStudentNames}}" wx:key="*this" class="score-selected-tag">
              <text>{{item}}</text>
              <text class="score-selected-tag-remove" bindtap="removeStudent" data-index="{{index}}">✕</text>
            </view>
            <view wx:if="{{analysisConfig.selectedStudentNames.length < 6}}" bindtap="openStudentPicker" class="analysis-trigger">+ 添加学员</view>
          </view>
        </view>

        <!-- 时间范围 -->
        <view class="filter-section">
          <view class="label">时间范围</view>
          <picker bindchange="onTimeRangeChange" range="{{timeRangeOptions}}" range-key="label">
            <view class="input score-picker-row">
              <text class="body-text text-13">{{timeRangeLabel}}</text>
              <text class="caption-text">▼</text>
            </view>
          </picker>
        </view>

        <!-- 自定义日期 -->
        <view wx:if="{{analysisConfig.timeRange === 'custom'}}" class="flex gap-8 mb-10">
          <view class="flex-1">
            <view class="label">开始日期</view>
            <picker mode="date" bindchange="onStartDateChange" value="{{analysisConfig.startDate}}">
              <view class="input score-picker-row">
                <text class="body-text text-13">{{analysisConfig.startDate || '选择日期'}}</text>
              </view>
            </picker>
          </view>
          <view class="flex-1">
            <view class="label">结束日期</view>
            <picker mode="date" bindchange="onEndDateChange" value="{{analysisConfig.endDate}}">
              <view class="input score-picker-row">
                <text class="body-text text-13">{{analysisConfig.endDate || '选择日期'}}</text>
              </view>
            </picker>
          </view>
        </view>

        <!-- 阶段筛选 -->
        <view class="filter-section">
          <view class="label">阶段筛选</view>
          <picker bindchange="onStageFilterChange" range="{{stageOptions}}">
            <view class="input score-picker-row">
              <text class="body-text text-13">{{stageFilterLabel}}</text>
              <text class="caption-text">▼</text>
            </view>
          </picker>
        </view>

        <!-- 扇区 -->
        <view class="filter-section">
          <view class="label">扇区</view>
          <view class="score-option-grid">
            <view class="sector-card {{analysisConfig.sector === 'ACC02_32' ? 'active' : ''}}" bindtap="switchAnalysisSector" data-sector="ACC02_32">
              <view class="caption-text font-mono-alt">ACC02/32</view>
            </view>
            <view class="sector-card {{analysisConfig.sector === 'ACC08' ? 'active' : ''}}" bindtap="switchAnalysisSector" data-sector="ACC08">
              <view class="caption-text font-mono-alt">ACC08</view>
            </view>
            <view class="sector-card {{analysisConfig.sector === 'ACC18_28' ? 'active' : ''}}" bindtap="switchAnalysisSector" data-sector="ACC18_28">
              <view class="caption-text font-mono-alt">ACC18/28</view>
            </view>
          </view>
        </view>

        <!-- 图表类型 -->
        <view class="filter-section">
          <view class="label">图表类型</view>
          <view class="score-option-grid">
            <view class="sector-card {{analysisConfig.chartType === 'radar' ? 'active' : ''}}" bindtap="switchChartType" data-type="radar">
              <view class="caption-text">雷达图</view>
            </view>
            <view class="sector-card {{analysisConfig.chartType === 'bar' ? 'active' : ''}}" bindtap="switchChartType" data-type="bar">
              <view class="caption-text">柱形图</view>
            </view>
            <view class="sector-card {{analysisConfig.chartType === 'line' ? 'active' : ''}}" bindtap="switchChartType" data-type="line">
              <view class="caption-text">折线图</view>
            </view>
          </view>
        </view>

        <!-- 对比维度 -->
        <view class="filter-section-lg">
          <view class="label">对比维度</view>
          <view class="score-option-grid">
            <view class="sector-card {{analysisConfig.compareDimension === 'student' ? 'active' : ''}}" bindtap="switchCompareDimension" data-dim="student">
              <view class="caption-text">学员对比</view>
            </view>
            <view class="sector-card {{analysisConfig.compareDimension === 'time' ? 'active' : ''}}" bindtap="switchCompareDimension" data-dim="time">
              <view class="caption-text">时间趋势</view>
            </view>
            <view class="sector-card {{analysisConfig.compareDimension === 'category' ? 'active' : ''}}" bindtap="switchCompareDimension" data-dim="category">
              <view class="caption-text">分类对比</view>
            </view>
          </view>
        </view>

        <view class="btn btn-primary btn-block h-42 text-15 ls-1" bindtap="generateAnalysis">生成图表</view>
      </block>
    </view>

    <!-- 图表区域 -->
    <view class="card chart-panel" wx:if="{{chartData}}">
      <view class="flex-between mb-8">
        <view class="card-title card-title-no-border">
          <text wx:if="{{analysisConfig.chartType === 'radar'}}">能力雷达</text>
          <text wx:if="{{analysisConfig.chartType === 'bar'}}">柱形对比</text>
          <text wx:if="{{analysisConfig.chartType === 'line'}}">趋势折线</text>
        </view>
        <text class="text-11 text-muted">{{analysisConfig.sector === 'ACC02_32' ? 'ACC02/32' : analysisConfig.sector === 'ACC08' ? 'ACC08' : 'ACC18/28'}}</text>
      </view>
      <canvas type="2d" id="analysisChartCanvas" class="chart-canvas"></canvas>
      <!-- 图例 -->
      <view class="chart-legend">
        <view wx:for="{{chartData.datasets}}" wx:key="name" class="chart-legend-item">
          <!-- dynamic: background -->
          <view class="chart-legend-dot" style="background:{{item.color}};"></view>
          <text class="chart-legend-label">{{item.name}}</text>
        </view>
      </view>
    </view>

    <!-- 数据洞察 -->
    <view class="card mb-12" wx:if="{{insightCards.length > 0}}">
      <view class="card-title card-title-bar">数据洞察</view>
      <view wx:for="{{insightCards}}" wx:key="title" class="insight-card-inner">
        <view class="flex-center-gap6 mb-8">
          <text class="insight-icon">{{item.icon}}</text>
          <text class="insight-title-text-inner">{{item.title}}</text>
        </view>
        <view wx:for="{{item.items}}" wx:for-item="line" wx:key="*this" class="insight-line-inner">{{line}}</view>
      </view>
    </view>

    <!-- 数据明细表格 -->
    <view class="card mb-12" wx:if="{{analysisDatasets.length > 0}}">
      <view class="card-title card-title-bar">数据明细</view>
      <view wx:for="{{analysisDatasets}}" wx:key="student.userId" class="mb-14">
        <view class="detail-student-name">{{item.student.name}} {{item.student.level ? '(' + item.student.level + ')' : ''}}</view>
        <view class="detail-table-wrap">
          <view class="detail-table-header">
            <text class="w-60">日期</text>
            <text class="w-45 text-center">总分</text>
            <text class="flex-1 text-center">等级</text>
          </view>
          <view wx:for="{{item.scores}}" wx:for-item="sc" wx:for-index="scIdx" wx:key="scIdx" class="detail-table-row">
            <text class="w-60 text-muted font-mono-alt">{{sc.date}}</text>
            <!-- dynamic: color -->
            <text class="w-45 text-center fw-700 font-mono-alt" style="color:{{sc.totalScore >= 90 ? 'var(--radar-green)' : sc.totalScore >= 85 ? 'var(--amber)' : 'var(--alert-red)'}};">{{sc.totalScore}}</text>
            <text class="flex-1 text-center text-secondary">{{sc.totalScore >= 95 ? '优秀' : sc.totalScore >= 90 ? '良好' : sc.totalScore >= 85 ? '合格' : '不合格'}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 未生成图表提示 -->
    <view class="empty-state empty-state-padded" wx:if="{{!chartData}}">
      <view class="empty-icon">📊</view>
      <view class="empty-title-md">请选择条件并生成图表</view>
      <view class="empty-desc">选择学员、时间、扇区等条件，点击「生成图表」开始分析</view>
    </view>

    <view class="spacer-40"></view>
  </block>

  <!-- ========== 学员友好提示 ========== -->
  <block wx:if="{{!canScore && !isManager}}">
    <view class="empty-state empty-state-padded-lg">
      <view class="empty-icon">📝</view>
      <view class="empty-title-lg">评分功能</view>
      <view class="empty-desc-lg">
        评分功能仅限教员和管理员使用<br/>
        您的评估记录可在「管理」页面查看
      </view>
    </view>
  </block>

  <!-- ========== 学员选择弹窗 ========== -->
  <view wx:if="{{showStudentPicker}}" class="modal-overlay" bindtap="closeStudentPicker">
    <view class="modal-body" catchtap="preventClose">
      <view class="modal-header">
        <text class="modal-title">选择学员</text>
        <text bindtap="closeStudentPicker" class="modal-close">关闭</text>
      </view>
      <scroll-view scroll-y class="scroll-y-320">
        <view wx:for="{{pickerStudents}}" wx:key="userId" bindtap="toggleStudentSelection" data-id="{{item.userId}}" class="student-picker-item">
          <view>
            <text class="modal-student-name">{{item.name}}</text>
            <text class="modal-student-level">{{item.level || '未设置阶段'}}</text>
          </view>
          <!-- dynamic: border-color -->
          <view class="student-picker-check" style="border-color:{{item.selected ? 'var(--radar-green)' : 'var(--text-muted)'}};">
            <view wx:if="{{item.selected}}" class="student-picker-check-inner"></view>
          </view>
        </view>
      </scroll-view>
      <view class="modal-footer">
        <view class="btn btn-primary btn-block modal-confirm-btn" bindtap="confirmStudentSelection">确认选择（已选 {{selectedStudentCount}} 人）</view>
      </view>
    </view>
  </view>

  <!-- 学员选择底部面板 -->
  <view class="bottom-panel-overlay" wx:if="{{showStudentPanel}}" bindtap="closeStudentPanel"></view>
  <view class="bottom-panel" wx:if="{{showStudentPanel}}">
    <view class="bottom-panel-header">
      <text class="bottom-panel-title">选择学员</text>
      <text class="bottom-panel-close" bindtap="closeStudentPanel">✕</text>
    </view>
    <view class="bottom-panel-list">
      <view wx:for="{{students}}" wx:key="userId"
        class="bottom-panel-item"
        data-id="{{item.userId}}"
        bindtap="selectStudentFromPanel">
        <view class="bottom-panel-item-info">
          <view class="bottom-panel-item-name">{{item.name}}</view>
        </view>
        <text wx:if="{{selectedStudent && selectedStudent === item.userId}}" class="bottom-panel-item-check">✓</text>
      </view>
    </view>
  </view>

  <!-- 提交确认弹窗 -->
  <view wx:if="{{showSubmitConfirm}}" class="modal-overlay" bindtap="cancelSubmit">
    <view class="modal-body submit-confirm-modal" catchtap="">
      <view class="modal-header">
        <text class="modal-title">确认提交评分</text>
        <text bindtap="cancelSubmit" class="modal-close">✕</text>
      </view>
      <scroll-view scroll-y class="submit-confirm-scroll">
        <view class="submit-confirm-score-row">
          <view class="submit-confirm-score-value" style="color:{{gradeColor}};">{{totalScore}}</view>
          <view class="submit-confirm-score-unit">/ {{maxTotalScore || 100}} 分</view>
          <view class="score-badge" style="background:{{gradeColor}}15;color:{{gradeColor}};border:1px solid {{gradeColor}}30;margin-left:12px;">{{gradeText}}</view>
        </view>
        <view class="submit-confirm-student">{{selectedStudentName}} · {{sectorConfigNames[sector] || sector}}</view>

        <view class="submit-confirm-section">
          <view class="submit-confirm-section-title">分类得分</view>
          <view wx:for="{{confirmCategorySummary}}" wx:key="name" class="submit-confirm-cat-row">
            <text class="submit-confirm-cat-name">{{item.name}}</text>
            <view class="submit-confirm-cat-bar-wrap">
              <view class="submit-confirm-cat-bar" style="width:{{item.rate}}%;background:{{item.rate >= 85 ? 'var(--radar-green)' : item.rate >= 70 ? 'var(--amber)' : 'var(--alert-red)'}};"></view>
            </view>
            <text class="submit-confirm-cat-score" style="color:{{item.rate >= 85 ? 'var(--radar-green)' : item.rate >= 70 ? 'var(--amber)' : 'var(--alert-red)'}};">{{item.score}}/{{item.maxScore}}</text>
          </view>
        </view>

        <view wx:if="{{confirmDeductions.length > 0}}" class="submit-confirm-section">
          <view class="submit-confirm-section-title">扣分明细（{{confirmDeductions.length}}项）</view>
          <view wx:for="{{confirmDeductions}}" wx:key="name" class="submit-confirm-deduct-row">
            <text class="submit-confirm-deduct-name">{{item.name}}</text>
            <text class="submit-confirm-deduct-val">-{{item.deduct}}分</text>
          </view>
        </view>
      </scroll-view>
      <view class="modal-footer submit-confirm-footer">
        <view class="btn btn-secondary submit-confirm-cancel" bindtap="cancelSubmit">返回修改</view>
        <view class="btn btn-primary submit-confirm-ok" bindtap="confirmSubmit" loading="{{submitting}}">{{submitting ? '提交中...' : '确认提交'}}</view>
      </view>
    </view>
  </view>

  <!-- ========== 评分流程全屏面板 ========== -->
  <view class="score-flow-overlay" wx:if="{{showScoreFlow}}">
    <view class="score-flow-panel">
      <!-- 顶部标题栏 -->
      <view class="score-flow-topbar">
        <view class="score-flow-topbar-title">
          <text wx:if="{{scoreStep===1}}">选择学员</text>
          <text wx:if="{{scoreStep===2}}">选择扇区</text>
          <text wx:if="{{scoreStep===3}}">{{selectedStudentName}} · {{sectorConfigNames[sector] || sector}}</text>
        </view>
        <view class="score-flow-topbar-close" bindtap="closeScoreFlow">✕</view>
      </view>

      <!-- 步骤指示器 -->
      <view class="score-flow-steps">
        <view class="score-flow-step {{scoreStep >= 1 ? 'active' : ''}}">
          <view class="score-flow-step-num">1</view>
          <text class="score-flow-step-label">选择学员</text>
        </view>
        <view class="score-flow-step-line {{scoreStep >= 2 ? 'active' : ''}}"></view>
        <view class="score-flow-step {{scoreStep >= 2 ? 'active' : ''}}">
          <view class="score-flow-step-num">2</view>
          <text class="score-flow-step-label">选择扇区</text>
        </view>
        <view class="score-flow-step-line {{scoreStep >= 3 ? 'active' : ''}}"></view>
        <view class="score-flow-step {{scoreStep >= 3 ? 'active' : ''}}">
          <view class="score-flow-step-num">3</view>
          <text class="score-flow-step-label">分步评分</text>
        </view>
      </view>

      <!-- 步骤1：选择学员 -->
      <block wx:if="{{scoreStep === 1}}">
        <scroll-view scroll-y class="score-flow-body">
          <view class="score-flow-section-title">请选择要评分的学员</view>
          <view wx:for="{{students}}" wx:key="userId"
            class="score-flow-student-item {{selectedStudent === item.userId ? 'selected' : ''}}"
            data-id="{{item.userId}}"
            bindtap="selectStudentInFlow">
            <view class="score-flow-student-name">{{item.name}}</view>
            <text wx:if="{{selectedStudent === item.userId}}" class="score-flow-student-check">✓</text>
          </view>
        </scroll-view>
        <view class="score-flow-footer">
          <view class="btn btn-secondary score-flow-btn" bindtap="closeScoreFlow">取消</view>
          <view class="btn btn-primary score-flow-btn {{selectedStudent ? '' : 'disabled'}}" bindtap="nextStep">下一步</view>
        </view>
      </block>

      <!-- 步骤2：选择扇区 -->
      <block wx:if="{{scoreStep === 2}}">
        <scroll-view scroll-y class="score-flow-body">
          <view class="score-flow-section-title">请选择评分扇区</view>
          <view wx:if="{{sectorConfigLoading}}" class="score-loading">
            <text class="score-loading-text">正在加载扇区配置...</text>
          </view>
          <view wx:else class="score-flow-sector-list">
            <view wx:for="{{sectorConfigKeys}}" wx:key="*this"
              class="score-flow-sector-item {{sector === item ? 'selected' : ''}}"
              data-sector="{{item}}"
              bindtap="selectSectorInFlow">
              <view class="score-flow-sector-name">{{sectorConfigNames[item] || item}}</view>
              <text wx:if="{{sector === item}}" class="score-flow-student-check">✓</text>
            </view>
          </view>
        </scroll-view>
        <view class="score-flow-footer">
          <view class="btn btn-secondary score-flow-btn" bindtap="prevStep">上一步</view>
          <view class="btn btn-primary score-flow-btn {{sector ? '' : 'disabled'}}" bindtap="nextStep">下一步</view>
        </view>
      </block>

      <!-- 步骤3：评分 -->
      <block wx:if="{{scoreStep === 3}}">
        <!-- 实时总分条 -->
        <view class="score-flow-totalbar">
          <view class="score-flow-totalbar-left">
            <text class="score-flow-totalbar-label">当前总分</text>
            <text class="score-flow-totalbar-value" style="color:{{gradeColor}};">{{totalScore}}</text>
            <text class="score-flow-totalbar-unit">/ {{maxTotalScore || 100}}</text>
          </view>
          <view class="score-flow-totalbar-right">
            <view class="score-badge" style="background:{{gradeColor}}15;color:{{gradeColor}};border:1px solid {{gradeColor}}30;">{{gradeText}}</view>
          </view>
        </view>
        <view class="score-flow-progress-wrap">
          <view class="progress-bar" style="height:6px;">
            <view class="progress-fill" style="width:{{scoredPct}}%;background:{{totalScore >= maxTotalScore * 0.9 ? 'var(--success)' : totalScore >= maxTotalScore * 0.75 ? 'var(--warning)' : 'var(--accent-blue)'}};"></view>
          </view>
          <text class="score-flow-progress-text">已评 {{scoredItemCount}}/{{totalItemCount}} 项</text>
        </view>

        <!-- 分类进度指示器 -->
        <view class="score-category-progress" wx:if="{{sectorConfig.categories.length > 0}}">
          <view class="score-category-progress-bar">
            <view class="score-category-progress-fill" style="width:{{(scoringCategoryIndex + 1) / sectorConfig.categories.length * 100}}%;"></view>
          </view>
          <text class="score-category-progress-text">第 {{scoringCategoryIndex + 1}} / {{sectorConfig.categories.length}} 项：{{sectorConfig.categories[scoringCategoryIndex].name}}</text>
        </view>

        <scroll-view scroll-y class="score-flow-body score-flow-body-scoring">
          <!-- 当前评分分类 -->
          <view wx:if="{{sectorConfig.categories[scoringCategoryIndex]}}" class="card mb-10">
            <view class="score-category-header flex-between">
              <view class="flex-1 min-w-0">
                <view class="score-category-title">{{sectorConfig.categories[scoringCategoryIndex].name}}</view>
                <view class="score-category-meta">满分{{sectorConfig.categories[scoringCategoryIndex].maxScore}}分 | 合格线{{sectorConfig.categories[scoringCategoryIndex].minScore || 0}}分 | {{sectorConfig.categories[scoringCategoryIndex].items.length}}个评分项</view>
              </view>
              <view class="flex-center-gap10 flex-shrink-0">
                <text class="score-category-score" style="color:{{catRatePass[sectorConfig.categories[scoringCategoryIndex].id] ? 'var(--radar-green)' : 'var(--alert-red)'}};">{{categoryScores[sectorConfig.categories[scoringCategoryIndex].id] || 0}}/{{sectorConfig.categories[scoringCategoryIndex].maxScore}}</text>
              </view>
            </view>

            <view class="score-item-divider">
              <view wx:for="{{sectorConfig.categories[scoringCategoryIndex].items}}" wx:key="id" wx:for-item="item" class="score-item-box">
                <view class="score-item-header">
                  <view class="score-item-title-wrap">
                    <view class="body-text text-14 lh-145">{{item.name}}</view>
                    <view wx:if="{{item.description}}" class="caption-text mt-3 lh-13 text-secondary">{{item.description}}</view>
                  </view>
                  <view class="score-item-input-wrap">
                    <input class="input score-input-narrow" type="number" step="1"
                           value="{{scores[sectorConfig.categories[scoringCategoryIndex].id+'_'+item.id] || ''}}" placeholder="0" placeholder-class="placeholder"
                           data-cat="{{sectorConfig.categories[scoringCategoryIndex].id}}" data-item="{{item.id}}" data-max="{{item.maxScore}}"
                           bindinput="onScoreInput" />
                    <text class="caption-text font-mono-alt">/{{item.maxScore}}</text>
                  </view>
                </view>
                <view class="flex-wrap-gap8 mt-6" wx:if="{{item.maxScore <= 20}}">
                  <view class="btn btn-secondary btn-text-sm btn-sm" data-cat="{{sectorConfig.categories[scoringCategoryIndex].id}}" data-item="{{item.id}}" data-val="{{item.maxScore}}" bindtap="quickScoreItem">满分{{item.maxScore}}分</view>
                  <view wx:if="{{item.maxScore >= 3}}" class="btn btn-secondary btn-text-sm btn-sm" data-cat="{{sectorConfig.categories[scoringCategoryIndex].id}}" data-item="{{item.id}}" data-val="{{item.maxScore - 1}}" bindtap="quickScoreItem">扣1分→{{item.maxScore - 1}}分</view>
                  <view wx:if="{{item.maxScore >= 5}}" class="btn btn-secondary btn-text-sm btn-sm" data-cat="{{sectorConfig.categories[scoringCategoryIndex].id}}" data-item="{{item.id}}" data-val="{{item.maxScore - 2}}" bindtap="quickScoreItem">扣2分→{{item.maxScore - 2}}分</view>
                </view>
                
                <view class="progress-bar">
                  <view class="progress-fill" style="width:{{item.maxScore > 0 ? ((scores[sectorConfig.categories[scoringCategoryIndex].id+'_'+item.id]||0)/item.maxScore*100) : 0}}%;background:{{(scores[sectorConfig.categories[scoringCategoryIndex].id+'_'+item.id]||0) >= item.maxScore*0.7 ? 'var(--radar-green)' : (scores[sectorConfig.categories[scoringCategoryIndex].id+'_'+item.id]||0) > 0 ? 'var(--amber)' : 'var(--border-color)'}};"></view>
                </view>

                <view wx:if="{{item._quickScores && item._quickScores.length > 0}}" class="flex-wrap-gap6 mt-8">
                  <view wx:for="{{item._quickScores}}" wx:key="*this" wx:for-item="deduction"
                        class="score-quick-btn {{(scores[sectorConfig.categories[scoringCategoryIndex].id+'_'+item.id] || 0) === (item.maxScore - deduction) ? 'active' : ''}}" 
                        bindtap="onQuickScore" data-cat="{{sectorConfig.categories[scoringCategoryIndex].id}}" data-item="{{item.id}}" data-max="{{item.maxScore}}" data-val="{{deduction}}">
                    {{deduction === 0 ? '满分' : '扣' + deduction + '分'}}
                  </view>
                </view>

                <view wx:if="{{item.maxScore > 0 && (scores[sectorConfig.categories[scoringCategoryIndex].id+'_'+item.id] || 0) < item.maxScore}}" class="item-reason-box">
                  <view class="item-reason-label">扣分说明（未满分必填）</view>
                  <textarea class="item-reason-textarea" 
                            value="{{scoreReasons[sectorConfig.categories[scoringCategoryIndex].id+'_'+item.id] || ''}}"
                            placeholder="请说明扣分原因（例如：具体哪一步、出现了什么问题、造成了什么影响）"
                            bindinput="onReasonInput" data-cat="{{sectorConfig.categories[scoringCategoryIndex].id}}" data-item="{{item.id}}" maxlength="200" />
                  <view class="item-reason-hint">{{(_reasonLengths[sectorConfig.categories[scoringCategoryIndex].id+'_'+item.id] || 0)}}/200</view>
                </view>
              </view>
            </view>
          </view>
          <view class="spacer-20"></view>
        </scroll-view>

        <view class="score-flow-footer">
          <view class="btn btn-secondary score-flow-btn" bindtap="prevStep">上一步</view>
          <view wx:if="{{scoringCategoryIndex < sectorConfig.categories.length - 1}}" class="btn btn-primary score-flow-btn" bindtap="nextStep">下一步</view>
          <view wx:else class="btn btn-primary score-flow-btn" bindtap="submitScore">提交评分</view>
        </view>
      </block>
    </view>
  </view>

  <!-- Toast提示 -->
  <view wx:if="{{toast}}" class="toast-box" bindtap="setData" data-toast="">
    <text class="text-14 text-primary">{{toast}}</text>
  </view>
</view>