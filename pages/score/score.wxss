/* pages/score/score.wxss */

/* 个人信息卡片（复用 mygrades 样式） */
.mygrades-profile-card {
  margin-bottom: 12px;
  padding: 14px;
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, var(--bg-surface-1, #0f1724), rgba(19, 34, 56, 0.9));
  border: 1px solid var(--border-subtle, #1a2740);
}

.mygrades-profile-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(90deg, rgba(37, 99, 235, 0.6), rgba(37, 99, 235, 0.15), transparent);
}

.mygrades-profile {
  display: flex;
  align-items: center;
  gap: 12px;
}

.mygrades-profile-avatar {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: var(--bg-surface-2, #162033);
  flex-shrink: 0;
  border: 2px solid rgba(37, 99, 235, 0.35);
  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.08), 0 4px 12px rgba(0, 0, 0, 0.25);
}

.mygrades-profile-avatar-btn {
  padding: 0;
  margin: 0;
  background: none;
  border: none;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mygrades-profile-avatar-btn::after {
  border: none;
}

.mygrades-profile-body {
  flex: 1;
  min-width: 0;
}

.mygrades-profile-top {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

.mygrades-profile-name {
  font-size: 17px;
  font-weight: 700;
  color: var(--text-primary, #e8ecf1);
  letter-spacing: 0.3px;
}

.mygrades-profile-age {
  font-size: 12px;
  color: var(--text-muted, #4a5d75);
}

.mygrades-profile-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 6px;
}

.mygrades-profile-meta-item {
  font-size: 11px;
  color: var(--text-secondary, #8a9bb0);
  background: rgba(22, 45, 69, 0.5);
  padding: 3px 10px;
  border-radius: 999px;
  border: 1px solid rgba(30, 58, 95, 0.5);
  font-weight: 500;
  letter-spacing: 0.2px;
}

.score-toolbar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
  gap: 8px;
}

.score-card-gradient {
  margin-bottom: 12px;
  background: linear-gradient(135deg, var(--bg-secondary, #132238), var(--bg-primary, #0a1628));
}

.score-margin-card {
  margin-bottom: 12px;
}

.score-form-group {
  margin-bottom: 0;
}

.score-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.score-picker-val {
  color: var(--text-primary, #e8ecf1);
}

.score-picker-placeholder {
  color: var(--text-muted, #4a5d75);
}

.score-picker-arrow {
  color: var(--text-muted, #4a5d75);
  font-size: 12px;
}

.score-loading {
  padding: 10px 0;
  text-align: center;
}

.score-loading-text {
  font-size: 13px;
  color: var(--text-secondary, #8a9bb0);
}

.score-sector-grid {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.score-sector-item {
  flex: 1;
  min-width: 70px;
  max-width: 140px;
}

.score-sector-item {
  text-align: center;
  padding: 10px 0;
}

.score-sector-item-title {
  font-weight: 700;
  font-size: 14px;
  font-family: monospace;
}

.score-sector-item-subtitle {
  font-size: 11px;
  color: var(--text-muted, #4a5d75);
  margin-top: 2px;
}

.picker {
  color: var(--text-primary, #e8ecf1);
}

.placeholder {
  color: var(--text-muted, #4a5d75);
}

/* 数据分析页面额外样式 */
.analysis-card {
  background: var(--bg-primary, #0a1628);
  border-radius: 6px;
  border: 1px solid var(--bg-tertiary, #1a2d45);
  padding: 12px;
  margin-bottom: 10px;
  overflow: hidden;
}

.radar-legend {
  display: flex;
  justify-content: center;
  gap: 20px;
  margin-top: 8px;
  /* 小屏时自动换行，避免溢出 */
  flex-wrap: wrap;
}

.radar-legend-item {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 12px;
  color: var(--text-secondary, #8a9bb0);
  /* 防止 flex 容器中被挤压变形 */
  flex-shrink: 0;
  min-width: 0;
}

.radar-legend-dot {
  width: 12px;
  height: 12px;
  border-radius: 2px;
  flex-shrink: 0;
}

.radar-legend-line {
  width: 16px;
  height: 3px;
  border-radius: 1px;
  flex-shrink: 0;
}

/* 数据明细表格 */
.score-table-header {
  display: flex;
  padding: 8px 10px;
  background: var(--bg-tertiary, #1a2d45);
  font-size: 11px;
  color: var(--text-secondary, #8a9bb0);
}

.score-table-row {
  display: flex;
  padding: 7px 10px;
  border-top: 1px solid var(--bg-tertiary, #1a2d45);
  font-size: 12px;
}

/* 洞察卡片 */
.insight-card {
  margin-bottom: 10px;
  padding: 12px;
  background: var(--bg-primary, #0a1628);
  border-radius: 6px;
  border: 1px solid var(--bg-tertiary, #1a2d45);
}

.insight-title {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 8px;
}

.insight-title-text {
  font-size: 13px;
  font-weight: 700;
  color: var(--text-primary, #e8ecf1);
}

.insight-line {
  font-size: 12px;
  color: var(--text-secondary, #8a9bb0);
  line-height: 1.9;
  padding-left: 4px;
  word-break: break-word;
  overflow-wrap: break-word;
}

/* 快捷分按钮 */
.score-quick-btns {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  margin-top: 6px;
}

.score-quick-btn {
  min-height: 32px;
  padding: 4px 12px;
  border-radius: 6px;
  border: 1px solid var(--border-color, #1e3a5f);
  background: var(--bg-tertiary, #1a2d45);
  color: var(--text-secondary, #8a9bb0);
  font-size: 12px;
  transition: all 0.15s;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.score-quick-btn.active {
  border-color: var(--accent-blue, #2563eb);
  color: #fff;
  background: rgba(37, 99, 235, 0.35);
}

/* 学员选择弹窗 */
.student-picker-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 10001;
  display: flex;
  align-items: center;
  justify-content: center;
}

.student-picker-body {
  width: 82%;
  max-width: 340px;
  background: var(--bg-secondary, #132238);
  border-radius: 12px;
  border: 1px solid var(--border-color, #1e3a5f);
  overflow: hidden;
}

.student-picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 16px;
  border-bottom: 1px solid var(--bg-tertiary, #1a2d45);
}

.student-picker-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary, #e8ecf1);
}

.student-picker-close {
  color: var(--text-muted, #4a5d75);
  font-size: 13px;
}

.student-picker-item {
  padding: 12px 16px;
  border-bottom: 1px solid var(--bg-tertiary, #1a2d45);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.student-picker-name {
  color: var(--text-primary, #e8ecf1);
  font-size: 14px;
}

.student-picker-level {
  color: var(--text-muted, #4a5d75);
  font-size: 11px;
  margin-left: 8px;
}

.student-picker-radio {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  border: 2px solid var(--text-muted, #4a5d75);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.student-picker-radio-checked {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: var(--radar-green, #00d26a);
}

.student-picker-footer {
  padding: 12px 16px;
  border-top: 1px solid var(--bg-tertiary, #1a2d45);
}

/* 选中标签 */
.selected-tag {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 4px 10px;
  background: var(--bg-tertiary, #1a2d45);
  border-radius: 4px;
  font-size: 12px;
  border: 1px solid var(--border-color, #1e3a5f);
}

.selected-tag-text {
  color: var(--text-primary, #e8ecf1);
}

.selected-tag-remove {
  color: var(--alert-red, #ff4d4f);
  font-size: 11px;
  padding: 0 2px;
}

/* 已选学员计数 */
.selected-count {
  font-size: 11px;
  color: var(--text-secondary, #8a9bb0);
}

/* 小屏适配 */
@media (max-width: 375px) {
  .analysis-card {
    padding: 10px;
  }
  .radar-legend {
    gap: 12px;
  }
  .radar-legend-item {
    font-size: 11px;
  }
}


/* 分析面板进度条 */
.analysis-track {
  height: 8px;
  background: var(--bg-tertiary, #1a2d45);
  border-radius: 4px;
  overflow: hidden;
  position: relative;
}

/* 评分项手风琴头部点击热区增强 */
.score-category-header {
  padding: 8px 0;
  min-height: 44px;
}

/* 历史评分记录行 */
.score-history-row {
  padding: 10px 0;
  border-bottom: 1px solid var(--bg-tertiary, #1a2d45);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.score-history-row:last-child {
  border-bottom: none;
}

/* 数据分析筛选器中的选中标签 */
.score-selected-tag {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 4px 10px;
  background: var(--bg-tertiary, #1a2d45);
  border-radius: 4px;
  font-size: 12px;
  border: 1px solid var(--border-color, #1e3a5f);
}

.score-selected-tag text:first-child {
  color: var(--text-primary, #e8ecf1);
}

.score-selected-tag-remove {
  color: var(--alert-red, #ff4d4f);
  font-size: 11px;
  padding: 2px 4px;
  min-height: 24px;
  min-width: 24px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

/* 数据分析中的扇区/图表类型选择器通用样式 */
.score-option-grid {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}

.score-option-grid .sector-card {
  flex: 1;
  min-width: 70px;
  text-align: center;
  padding: 8px 0;
}

/* picker 输入框统一 */
.score-picker-row {
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 12px;
}

.analysis-track-sm {
  height: 6px;
  border-radius: 3px;
}

.analysis-threshold {
  position: absolute;
  top: 0;
  bottom: 0;
  width: 2px;
  z-index: 2;
}

.analysis-fill {
  height: 100%;
  border-radius: 4px;
  transition: width 0.3s ease;
}

.analysis-fill-sm {
  border-radius: 3px;
}

/* 汇总提示框 */
.analysis-summary-box {
  border-radius: 8px;
  padding: 10px 12px;
  margin-top: 10px;
}

.analysis-summary-box-weak {
  background: rgba(255, 77, 79, 0.08);
  border: 1px solid rgba(255, 77, 79, 0.2);
}

.analysis-summary-box-strong {
  background: rgba(0, 210, 106, 0.08);
  border: 1px solid rgba(0, 210, 106, 0.2);
}

.analysis-summary-title {
  font-size: 13px;
  font-weight: 600;
  margin-bottom: 6px;
}

.analysis-summary-title-weak {
  color: var(--alert-red, #ff4d4f);
}

.analysis-summary-title-strong {
  color: var(--radar-green, #00d26a);
}

.analysis-summary-content {
  font-size: 12px;
  color: var(--text-secondary, #8a9bb0);
  line-height: 1.6;
}

.analysis-summary-line {
  margin-bottom: 4px;
}

.analysis-summary-emphasis {
  font-weight: 600;
  color: var(--text-primary, #e8ecf1);
}

.analysis-summary-fail-note {
  color: var(--alert-red, #ff4d4f);
}

/* 单项进度条 */
.progress-bar {
  height: 4px;
  background: var(--bg-tertiary, #1a2d45);
  border-radius: 2px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 2px;
  transition: width 0.2s;
}

/* ===== 通用工具类：从 score.wxml 内联 style 提取 ===== */

