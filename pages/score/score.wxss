/* 组件类 */
.card-inner {
  margin-bottom: 10px;
  padding: 10px;
  background: var(--bg-primary, #0a1628);
  border-radius: 6px;
  border: 1px solid var(--bg-tertiary, #1a2d45);
}

.tag-btn {
  padding: 4px 12px;
  border-radius: 6px;
  font-size: 12px;
  min-height: 32px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.btn-text-sm {
  padding: 2px 8px;
  min-height: 28px;
  display: inline-flex;
  align-items: center;
}

.score-input-narrow {
  width: 70px;
  text-align: center;
  padding: 10px 8px;
  font-size: 17px;
  font-weight: 700;
  background: var(--bg-surface-2, #162033);
  border: 2px solid var(--border-subtle, #1a2740);
  color: var(--text-primary, #e8ecf1);
  border-radius: 8px;
  transition: all 0.2s ease;
}

.score-input-narrow:focus {
  border-color: var(--accent-blue, #3b82f6);
  background: var(--bg-surface-1, #0f1724);
}

.section-subtitle {
  font-size: 13px;
  font-weight: 600;
  color: var(--text-primary, #e8ecf1);
  margin-bottom: 10px;
}

.section-title-bar {
  margin-bottom: 10px;
}

.card-title-bar {
  margin-bottom: 12px;
}

.card-title-no-border {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.total-panel {
  margin-bottom: 12px;
  background: linear-gradient(135deg, var(--bg-secondary), #0f1d30);
}

.chart-panel {
  margin-bottom: 12px;
  background: linear-gradient(135deg, var(--bg-secondary), #0f1d30);
}

.toast-box {
  position: fixed;
  bottom: 100px;
  left: 16px;
  right: 16px;
  padding: 12px 16px;
  background: rgba(19, 34, 56, 0.96);
  border: 1px solid var(--border-color, #1e3a5f);
  border-radius: 8px;
  z-index: 1000;
  text-align: center;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-body {
  width: 82%;
  max-width: 340px;
  background: var(--bg-secondary, #132238);
  border-radius: 12px;
  border: 1px solid var(--border-color, #1e3a5f);
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 16px;
  border-bottom: 1px solid var(--bg-tertiary, #1a2d45);
}

.modal-footer {
  padding: 12px 16px;
  border-top: 1px solid var(--bg-tertiary, #1a2d45);
}

.empty-icon { font-size: 48px; margin-bottom: 16px; }
.empty-title-lg { font-size: 18px; font-weight: 700; color: var(--text-primary); margin-bottom: 8px; }
.empty-title-md { font-size: 16px; font-weight: 600; color: var(--text-primary); margin-bottom: 8px; }
.empty-desc { font-size: 13px; color: var(--text-muted); max-width: 260px; margin: 0 auto; line-height: 1.6; }
.empty-desc-lg { font-size: 14px; color: var(--text-secondary); line-height: 1.8; max-width: 280px; margin: 0 auto; }

.scroll-y-320 { max-height: 320px; }

.transition-transform { transition: transform 0.2s; }

.student-picker-check {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  border: 2px solid var(--text-muted, #4a5d75);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.student-picker-check-inner {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: var(--radar-green, #00d26a);
}

/* 历史评分 */
.history-date {
  font-size: 13px;
}

.history-meta {
  margin-top: 2px;
}

.history-alert {
  margin-bottom: 10px;
}

/* 数据分析 */
.analysis-panel {
  margin-top: 14px;
  padding-top: 14px;
  border-top: 1px solid var(--bg-tertiary, #1a2d45);
}

.analysis-progress-label {
  margin-bottom: 16px;
}

.analysis-progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6px;
}

.analysis-cat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4px;
}

.analysis-cat-item {
  margin-bottom: 10px;
}

.analysis-threshold-legend {
  display: flex;
  justify-content: flex-end;
  gap: 12px;
  margin-top: 4px;
}

/* 评分项 */
.score-item-box {
  margin-bottom: 12px;
  padding: 14px;
  background: var(--bg-primary, #0a1628);
  border-radius: 8px;
  border: 1px solid var(--bg-tertiary, #1a2d45);
}

.score-item-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 10px;
}

.score-item-title-wrap {
  flex: 1;
  padding-right: 12px;
  min-width: 0;
}

.score-item-input-wrap {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-shrink: 0;
}

.score-item-divider {
  margin-top: 14px;
  padding-top: 14px;
  border-top: 1px solid var(--bg-tertiary, #1a2d45);
}

.score-category-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary);
}

.score-category-meta {
  font-size: 12px;
  color: var(--text-muted);
  margin-top: 4px;
}

.score-category-score {
  font-size: 18px;
  font-weight: 700;
}

.score-category-toggle {
  font-size: 18px;
  color: var(--text-muted);
  transition: transform 0.2s;
}

/* 图表 */
.chart-canvas {
  width: 100%;
  height: 300px;
}

.chart-legend {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 14px;
  margin-top: 8px;
}

.chart-legend-item {
  display: flex;
  align-items: center;
  gap: 5px;
}

.chart-legend-dot {
  width: 10px;
  height: 10px;
  border-radius: 2px;
}

.chart-legend-label {
  font-size: 11px;
  color: var(--text-secondary);
}

/* 数据明细 */
.detail-table-wrap {
  background: var(--bg-primary, #0a1628);
  border-radius: 6px;
  border: 1px solid var(--bg-tertiary, #1a2d45);
  overflow: hidden;
}

.detail-table-header {
  display: flex;
  padding: 8px 10px;
  background: var(--bg-tertiary, #1a2d45);
  font-size: 11px;
  color: var(--text-secondary);
}

.detail-table-row {
  display: flex;
  padding: 7px 10px;
  border-top: 1px solid var(--bg-tertiary, #1a2d45);
  font-size: 12px;
}

.detail-student-name {
  font-size: 13px;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 6px;
}

/* 洞察卡片 */
.insight-card-inner {
  margin-bottom: 10px;
  padding: 12px;
  background: var(--bg-primary, #0a1628);
  border-radius: 6px;
  border: 1px solid var(--bg-tertiary, #1a2d45);
}

.insight-icon { font-size: 15px; }
.insight-title-text-inner { font-size: 13px; font-weight: 700; color: var(--text-primary); }
.insight-line-inner { font-size: 12px; color: var(--text-secondary); line-height: 1.9; padding-left: 4px; }

/* 提交按钮 */
.score-progress-bar {
  background: var(--bg-surface-2);
  border-radius: 12px;
  padding: 12px 16px;
  margin-bottom: 12px;
}
.score-progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}
.score-progress-text {
  font-size: 12px;
  color: var(--text-secondary);
}
.score-progress-total {
  font-size: 12px;
  color: var(--text-primary);
  font-weight: 600;
  font-family: 'SF Mono', Monaco, monospace;
}

.submit-btn {
  margin-top: 16px;
  margin-bottom: 16px;
  height: 48px;
  font-size: 16px;
  letter-spacing: 2px;
  display: flex;
  justify-content: center;
}

/* 底部占位 */
.spacer-40 { height: 40px; }

/* 筛选面板 */
.filter-section { margin-bottom: 10px; }
.filter-section-lg { margin-bottom: 12px; }

/* 弹窗 */
.modal-title { font-size: 15px; font-weight: 600; color: var(--text-primary); }
.modal-close { color: var(--text-muted); font-size: 13px; }
.modal-student-name { color: var(--text-primary); font-size: 14px; }
.modal-student-level { color: var(--text-muted); font-size: 11px; margin-left: 8px; }
.modal-confirm-btn { height: 42px; font-size: 14px; }

/* 历史评分 */
.history-item-title { font-size: 13px; }
.history-item-meta { margin-top: 2px; }

/* 空状态 */
.empty-state-padded { padding-top: 60px; }
.empty-state-padded-lg { padding-top: 80px; }

/* 总分面板 */
.total-panel-grade {
  padding: 4px 14px;
  border-radius: 4px;
  font-size: 14px;
  font-weight: 700;
}

.total-panel-hint {
  margin-top: 6px;
  text-align: right;
}

/* 输入框聚焦增强 */
.input:focus, .batch-score-input:focus, .item-reason-textarea:focus {
  border-color: var(--accent-blue, #2563eb);
  box-shadow: 0 0 0 2px rgba(37, 99, 235, 0.15);
}

/* ========== 开始评分入口 ========== */
.score-start-card {
  margin-bottom: 12px;
  background: linear-gradient(135deg, rgba(37, 99, 235, 0.15), rgba(37, 99, 235, 0.05));
  border: 1px solid rgba(37, 99, 235, 0.3);
}

.score-start-content {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 16px;
}

.score-start-icon {
  font-size: 32px;
  flex-shrink: 0;
}

.score-start-text {
  flex: 1;
  min-width: 0;
}

.score-start-title {
  font-size: 16px;
  font-weight: 700;
  color: var(--text-primary, #e8ecf1);
}

.score-start-desc {
  font-size: 12px;
  color: var(--text-secondary, #8a9bb0);
  margin-top: 4px;
}

.score-start-arrow {
  font-size: 14px;
  color: var(--accent-blue, #2563eb);
  flex-shrink: 0;
}

/* ========== 评分流程全屏面板 ========== */
.score-flow-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-page, #070d17);
  z-index: 2000;
  display: flex;
  flex-direction: column;
  padding-bottom: calc(72px + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.score-flow-panel {
  display: flex;
  flex-direction: column;
  height: 100%;
  width: 100%;
}

/* 顶部标题栏 */
.score-flow-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 20px;
  background: var(--bg-secondary, #132238);
  border-bottom: 1px solid var(--border-color, #1e3a5f);
  flex-shrink: 0;
  min-height: 56px;
}

.score-flow-topbar-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary, #e8ecf1);
  flex: 1;
  text-align: center;
}

.score-flow-topbar-close {
  font-size: 20px;
  color: var(--text-muted, #4a5d75);
  padding: 8px 12px;
  flex-shrink: 0;
}

/* 步骤指示器 */
.score-flow-steps {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 16px 20px;
  background: var(--bg-secondary, #132238);
  border-bottom: 1px solid var(--border-color, #1e3a5f);
  flex-shrink: 0;
}

.score-flow-step {
  display: flex;
  align-items: center;
  gap: 8px;
  opacity: 0.4;
}

.score-flow-step.active {
  opacity: 1;
}

.score-flow-step-num {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: var(--bg-tertiary, #1a2d45);
  border: 2px solid var(--border-color, #1e3a5f);
  color: var(--text-secondary, #8a9bb0);
  font-size: 13px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.score-flow-step.active .score-flow-step-num {
  background: var(--accent-blue, #2563eb);
  border-color: var(--accent-blue, #2563eb);
  color: #fff;
}

.score-flow-step-label {
  font-size: 13px;
  color: var(--text-secondary, #8a9bb0);
}

.score-flow-step.active .score-flow-step-label {
  color: var(--text-primary, #e8ecf1);
  font-weight: 600;
}

.score-flow-step-line {
  width: 30px;
  height: 2px;
  background: var(--bg-tertiary, #1a2d45);
  border-radius: 1px;
}

.score-flow-step-line.active {
  background: var(--accent-blue, #2563eb);
}

/* 内容区 */
.score-flow-body {
  flex: 1;
  height: 0; /* 关键：scroll-view 在 flex 中需显式高度才能正确滚动 */
  padding: 16px 20px;
  -webkit-overflow-scrolling: touch;
  overflow-y: auto;
}

.score-flow-body-scoring {
  padding-top: 0;
}

.score-flow-section-title {
  font-size: 14px;
  color: var(--text-secondary, #8a9bb0);
  margin-bottom: 16px;
}

/* 学员/扇区选项 */
.score-flow-student-item,
.score-flow-sector-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 18px;
  background: var(--bg-surface-1, #0f1724);
  border: 1px solid var(--border-subtle, #1a2740);
  border-radius: 10px;
  margin-bottom: 12px;
  transition: all 0.2s ease;
}

.score-flow-student-item.selected,
.score-flow-sector-item.selected {
  border-color: var(--accent-blue, #2563eb);
  background: rgba(37, 99, 235, 0.12);
  box-shadow: 0 0 12px rgba(37, 99, 235, 0.15);
}

.score-flow-student-item:active,
.score-flow-sector-item:active {
  transform: scale(0.98);
}

.score-flow-student-name,
.score-flow-sector-name {
  font-size: 15px;
  color: var(--text-primary, #e8ecf1);
  font-weight: 500;
}

.score-flow-student-check {
  font-size: 18px;
  color: var(--accent-blue, #2563eb);
  font-weight: 700;
}

/* 实时总分条 */
.score-flow-totalbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 20px;
  background: var(--bg-secondary, #132238);
  border-bottom: 1px solid var(--border-color, #1e3a5f);
  flex-shrink: 0;
}

.score-flow-totalbar-left {
  display: flex;
  align-items: baseline;
  gap: 8px;
}

.score-flow-totalbar-label {
  font-size: 13px;
  color: var(--text-secondary, #8a9bb0);
}

.score-flow-totalbar-value {
  font-size: 28px;
  font-weight: 800;
  font-family: 'SF Mono', Monaco, monospace;
}

.score-flow-totalbar-unit {
  font-size: 14px;
  color: var(--text-muted, #4a5d75);
}

.score-flow-progress-wrap {
  padding: 8px 16px;
  background: var(--bg-secondary, #132238);
  border-bottom: 1px solid var(--border-color, #1e3a5f);
  flex-shrink: 0;
}

.score-flow-progress-text {
  font-size: 11px;
  color: var(--text-muted, #4a5d75);
  margin-top: 6px;
  display: block;
  text-align: right;
}

/* 分类进度指示器 */
.score-category-progress {
  padding: 10px 16px 6px;
  background: var(--bg-secondary, #132238);
  border-bottom: 1px solid var(--border-color, #1e3a5f);
}
.score-category-progress-bar {
  height: 4px;
  background: var(--border-color, #1e3a5f);
  border-radius: 2px;
  overflow: hidden;
  margin-bottom: 6px;
}
.score-category-progress-fill {
  height: 100%;
  background: var(--accent-blue, #2563eb);
  border-radius: 2px;
  transition: width 0.3s ease;
}
.score-category-progress-text {
  font-size: 12px;
  color: var(--text-secondary, #8a9bb0);
  display: block;
  text-align: center;
}

/* 底部按钮 */
.score-flow-footer {
  display: flex;
  gap: 12px;
  padding: 16px 20px calc(16px + env(safe-area-inset-bottom));
  background: var(--bg-secondary, #132238);
  border-top: 1px solid var(--border-color, #1e3a5f);
  flex-shrink: 0;
}

.score-flow-btn {
  flex: 1;
  height: 48px;
  font-size: 15px;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10px;
}

.score-flow-btn.disabled {
  opacity: 0.4;
  pointer-events: none;
}

.spacer-20 { height: 20px; }

/* 退出登录按钮 */
.manager-logout-btn {
  width: 100%;
  margin: 16px 0;
  padding: 12px 16px;
  text-align: center;
  color: var(--alert-red, #ff4d4f);
  font-size: 13px;
  font-weight: 600;
  border: 1px solid rgba(255, 77, 79, 0.2);
  border-radius: 8px;
  background: rgba(255, 77, 79, 0.05);
  letter-spacing: 0.5px;
}

.manager-logout-btn:active {
  background: rgba(255, 77, 79, 0.1);
}

/* 扣分说明 */
.item-reason-box {
  margin-top: 10px;
  padding-top: 10px;
  border-top: 1px dashed rgba(30, 58, 95, 0.8);
}

.item-reason-label {
  font-size: 12px;
  color: var(--text-secondary, #8a9bb0);
  margin-bottom: 6px;
}

.item-reason-textarea {
  width: 100%;
  min-height: 64px;
  padding: 8px 12px;
  font-size: 13px;
  box-sizing: border-box;
  border: 1px solid var(--border-color, #1e3a5f);
  border-radius: 6px;
  background: var(--bg-primary, #0a1628);
  color: var(--text-primary, #e8ecf1);
}

.item-reason-hint {
  margin-top: 6px;
  font-size: 11px;
  color: var(--text-muted, #4a5d75);
  text-align: right;
}

/* 提交确认弹窗 */
.submit-confirm-modal {
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}
.submit-confirm-scroll {
  max-height: 55vh;
  padding: 0 4px;
}
.submit-confirm-score-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
  padding: 16px 0 8px;
}
.submit-confirm-score-value {
  font-size: 48px;
  font-weight: 700;
  font-family: 'SF Mono', Monaco, monospace;
  line-height: 1;
}
.submit-confirm-score-unit {
  font-size: 16px;
  color: var(--text-secondary);
  margin-left: 4px;
}
.submit-confirm-student {
  text-align: center;
  font-size: 13px;
  color: var(--text-secondary);
  margin-bottom: 16px;
}
.submit-confirm-section {
  margin-bottom: 16px;
}
.submit-confirm-section-title {
  font-size: 13px;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8px;
  padding-bottom: 4px;
  border-bottom: 1px solid var(--border-color);
}
.submit-confirm-cat-row {
  display: flex;
  align-items: center;
  padding: 6px 0;
  gap: 8px;
}
.submit-confirm-cat-name {
  font-size: 12px;
  color: var(--text-secondary);
  width: 80px;
  flex-shrink: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.submit-confirm-cat-bar-wrap {
  flex: 1;
  height: 6px;
  background: var(--bg-primary);
  border-radius: 3px;
  overflow: hidden;
}
.submit-confirm-cat-bar {
  height: 100%;
  border-radius: 3px;
  transition: width 0.3s;
}
.submit-confirm-cat-score {
  font-size: 12px;
  font-weight: 600;
  font-family: 'SF Mono', Monaco, monospace;
  width: 52px;
  text-align: right;
  flex-shrink: 0;
}
.submit-confirm-deduct-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 5px 0;
  border-bottom: 1px solid rgba(30, 58, 95, 0.3);
}
.submit-confirm-deduct-name {
  font-size: 12px;
  color: var(--text-secondary);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 8px;
}
.submit-confirm-deduct-val {
  font-size: 12px;
  font-weight: 600;
  color: var(--alert-red);
  flex-shrink: 0;
}
.submit-confirm-footer {
  display: flex;
  gap: 12px;
  padding-top: 12px;
  border-top: 1px solid var(--border-color);
}
.submit-confirm-cancel {
  flex: 1;
  height: 40px;
}
.submit-confirm-ok {
  flex: 2;
  height: 40px;
}
