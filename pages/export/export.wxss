/* pages/export/export.wxss */

.export-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 0;
}

.export-spinner {
  width: 28px;
  height: 28px;
  border: 2px solid var(--border-color, #1e3a5f);
  border-top-color: var(--accent-blue, #2563eb);
  border-radius: 50%;
  animation: export-spin 0.8s linear infinite;
}

@keyframes export-spin {
  to { transform: rotate(360deg); }
}

.export-sheet-card {
  background: var(--bg-secondary, #132238);
  border: 1px solid var(--border-color, #1e3a5f);
  border-radius: 10px;
  margin-bottom: 12px;
  overflow: hidden;
}

.export-sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 16px;
  background: rgba(37, 99, 235, 0.06);
  border-bottom: 1px solid var(--border-color, #1e3a5f);
}

.export-sheet-icon {
  font-size: 10px;
  color: var(--text-muted, #4a5d75);
  width: 16px;
  text-align: center;
}

.export-action-link {
  font-size: 12px;
  color: var(--accent-blue, #2563eb);
  padding: 2px 4px;
}

.export-action-link:active {
  opacity: 0.7;
}

.export-fields-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  padding: 12px;
}

.export-field-item {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 10px;
  border-radius: 6px;
  background: var(--bg-primary, #0a1628);
  border: 1px solid var(--border-color, #1e3a5f);
  transition: all 0.15s;
  flex: 1 1 auto;
  min-width: 80px;
  max-width: calc(50% - 4px);
}

.export-field-item:active {
  background: rgba(37, 99, 235, 0.08);
}

.export-field-item--active {
  border-color: var(--accent-blue, #2563eb);
  background: rgba(37, 99, 235, 0.1);
}

.export-field-checkbox {
  width: 16px;
  height: 16px;
  border-radius: 3px;
  border: 2px solid var(--text-muted, #4a5d75);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.export-field-item--active .export-field-checkbox {
  border-color: var(--accent-blue, #2563eb);
  background: var(--accent-blue, #2563eb);
}

.export-field-checkinner {
  width: 8px;
  height: 8px;
  background: #fff;
  border-radius: 1px;
}

.export-field-label {
  font-size: 12px;
  color: var(--text-secondary, #8a9bb0);
  line-height: 1.3;
}

.export-field-item--active .export-field-label {
  color: var(--text-primary, #e8ecf1);
}

.export-btn-primary {
  text-align: center;
  padding: 14px 0;
  background: var(--accent-blue, #2563eb);
  border-radius: 8px;
  color: #fff;
  font-size: 15px;
  font-weight: 600;
}

.export-btn-primary:active {
  opacity: 0.9;
  background: #1d4ed8;
}
