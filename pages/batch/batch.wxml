<view class="container">
  <!-- 页面标题 -->
  <view class="page-header batch-page-header">
    <view class="page-header-title">批量评分</view>
    <view class="page-header-subtitle">一次性为多个学员评分</view>
  </view>

  <!-- 用户信息栏 -->
  <view class="batch-toolbar">
    <view class="trend-user-meta">
      <text class="trend-user-name" style="font-size:14px;">{{userInfo.name || '未登录'}}</text>
      <text wx:if="{{roleLabel}}" class="identity-badge identity-badge-role">{{roleLabel}}</text>
      <text wx:if="{{levelLabel}}" class="identity-badge identity-badge-level">{{levelLabel}}</text>
      <text wx:if="{{isManager}}" class="page-user-note" style="margin-left:8px;font-size:11px;color:var(--text-muted);">管理端</text>
    </view>
  </view>

  <!-- 错误提示 -->
  <view wx:if="{{bootError}}" class="card batch-error-card">
    <view class="batch-error-row">
      <text class="batch-error-text">{{bootError}}</text>
      <view bindtap="retryLoad" class="batch-retry-btn">重试</view>
    </view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{bootLoading}}" class="batch-loading-state">
    <view class="batch-loading-text">正在加载扇区与学员…</view>
    <view class="batch-skeleton-wrap">
      <view class="skeleton-row"></view>
      <view class="skeleton-row"></view>
    </view>
  </view>

  <block wx:if="{{!bootLoading}}">
    <!-- 扇区选择 -->
    <view class="card batch-sector-card">
      <view class="form-group" style="margin-bottom:0;">
        <view class="form-label">选择扇区</view>
        <picker bindchange="onSectorChange" range="{{sectors}}" range-key="name">
          <view class="picker input batch-picker">
            <text class="batch-picker-text {{sector ? '' : 'batch-picker-placeholder'}}">{{currentSectorName || '请选择扇区'}}</text>
            <text wx:if="{{categoryCountText}}" class="batch-picker-badge">{{categoryCountText}}</text>
            <text class="batch-picker-arrow" style="margin-left:auto;">▼</text>
          </view>
        </picker>
      </view>
    </view>

    <!-- 学员多选 -->
    <view class="card batch-students-card">
      <view class="batch-students-header">
        <view class="batch-card-title">选择学员</view>
        <view bindtap="selectAll" class="batch-select-all-btn {{students.length === 0 ? 'btn-disabled' : ''}}">
          {{selectedStudents.length === students.length && students.length > 0 ? '取消全选' : '全选'}}
        </view>
      </view>

      <view wx:if="{{students.length === 0}}" class="empty-state empty-state-compact">
        <text class="empty-text">暂无学员数据</text>
      </view>

      <view wx:for="{{students}}" wx:key="userId" class="batch-student-row" bindtap="toggleStudent" data-id="{{item.userId}}">
        <view class="batch-checkbox {{item.isSelected ? 'batch-checkbox-checked' : ''}}">
          <view wx:if="{{item.isSelected}}" class="batch-checkbox-inner"></view>
        </view>
        <view class="batch-student-info">
          <view class="batch-student-name">{{item.name}}</view>
          <view class="batch-student-username">{{item.username || item.userId}}</view>
        </view>
      </view>
    </view>

    <!-- 评分表单 -->
    <block wx:if="{{selectedStudents.length > 0 && categories.length > 0}}">
      <view class="card batch-score-form-card">
        <view class="batch-score-form-title">逐项打分</view>
        <view class="batch-score-hint">
          已选择 {{selectedStudents.length}} 位学员，为每位学员填写各维度得分
        </view>

        <view wx:for="{{selectedStudents}}" wx:key="*this" wx:for-item="studentId" class="batch-student-score-block">
          <view class="batch-student-score-title">{{studentNameMap[studentId]}}</view>

          <view wx:for="{{categories}}" wx:key="id" wx:for-item="cat" class="batch-category-row">
            <text class="batch-category-name">{{cat.name}}</text>
            <input class="batch-score-input" type="digit"
                   value="{{scores[studentId + '_' + cat.id] !== undefined ? scores[studentId + '_' + cat.id] : ''}}"
                   placeholder="/{{cat.maxScore}}" placeholder-class="placeholder"
                   data-student-id="{{studentId}}" data-category-id="{{cat.id}}" data-max="{{cat.maxScore}}"
                   bindinput="onScoreInput" />
          </view>

          <view class="batch-student-total">
            总分: {{studentTotals[studentId] || 0}} / {{currentSectorTotal}}
          </view>
        </view>
      </view>
    </block>

    <!-- 无评分维度提示 -->
    <view wx:if="{{selectedStudents.length > 0 && categories.length === 0 && sectors.length > 0}}" class="card batch-no-cat-card">
      <text class="batch-no-cat-text">当前扇区暂无评分维度配置，请先在「扇区配置」中维护。</text>
    </view>

    <!-- 提交按钮 -->
    <view wx:if="{{selectedStudents.length > 0}}" class="batch-submit-wrap">
      <view bindtap="handleSubmit" class="btn btn-primary btn-block {{loading || categories.length === 0 ? 'btn-disabled' : ''}}" style="{{loading || categories.length === 0 ? 'opacity:0.6;' : ''}}">
        {{loading ? '提交中...' : '提交评分 (' + selectedStudents.length + '人)'}}
      </view>
    </view>

    <!-- 提交结果 -->
    <view wx:if="{{result}}" class="card batch-result-card {{result.success ? 'batch-result-card--success' : 'batch-result-card--error'}}">
      <view class="batch-result-message">{{result.message || (result.success ? '评分成功' : '评分失败')}}</view>
      <view wx:if="{{result.data}}" class="batch-result-detail">
        成功: {{result.data.created || 0}} 条，失败: {{result.data.failed || 0}} 条
      </view>
      <view wx:if="{{result.created !== undefined}}" class="batch-result-detail">
        成功: {{result.created}} 条，失败: {{result.failed}} 条
      </view>
    </view>
  </block>
</view>
