/* pages/batch/batch.wxss */

.picker {
  color: var(--text-primary, #e8ecf1);
}

.placeholder {
  color: var(--text-muted, #4a5d75);
}

.btn-disabled {
  opacity: 0.6;
  pointer-events: none;
}

/* ==================== 页面头部 ==================== */
.batch-page-header {
  margin: -12px -12px 12px -12px;
}

/* ==================== 用户信息栏 ==================== */
.batch-toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
  gap: 8px;
}

.batch-user-meta {
  font-size: 13px;
  color: var(--text-primary, #e8ecf1);
  font-family: monospace;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.batch-user-note {
  font-size: 11px;
  color: var(--text-muted, #4a5d75);
  margin-left: 8px;
}

/* ==================== 错误卡片 ==================== */
.batch-error-card {
  background: rgba(255, 77, 79, 0.08);
  border-color: rgba(255, 77, 79, 0.25);
  margin-bottom: 12px;
}

.batch-error-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 8px;
}

.batch-error-text {
  font-size: 13px;
  color: var(--alert-red, #ff4d4f);
  flex: 1;
  word-break: break-word;
  overflow-wrap: break-word;
}

.batch-retry-btn {
  padding: 6px 12px;
  background: rgba(37, 99, 235, 0.15);
  border: 1px solid rgba(37, 99, 235, 0.3);
  border-radius: 6px;
  color: #60a5fa;
  font-size: 12px;
  white-space: nowrap;
  flex-shrink: 0;
}

/* ==================== 加载状态 ==================== */
.batch-loading-state {
  text-align: center;
  padding: 40px 20px;
}

.batch-loading-text {
  font-size: 13px;
  color: var(--text-secondary, #8a9bb0);
  margin-bottom: 16px;
}

.batch-skeleton-wrap {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

/* ==================== 扇区选择 ==================== */
.batch-sector-card {
  margin-bottom: 12px;
}

.batch-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}

.batch-picker-text {
  color: var(--text-primary, #e8ecf1);
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.batch-picker-placeholder {
  color: var(--text-muted, #4a5d75);
}

.batch-picker-badge {
  font-size: 11px;
  color: var(--text-secondary, #8a9bb0);
  background: rgba(37, 99, 235, 0.12);
  border: 1px solid rgba(37, 99, 235, 0.25);
  padding: 2px 8px;
  border-radius: 4px;
  white-space: nowrap;
  flex-shrink: 0;
}

.batch-picker-arrow {
  color: var(--text-muted, #4a5d75);
  font-size: 12px;
  flex-shrink: 0;
  margin-left: auto;
}

/* ==================== 学员选择卡片 ==================== */
.batch-students-card {
  margin-bottom: 12px;
}

.batch-students-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.batch-card-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary, #e8ecf1);
  display: flex;
  align-items: center;
  gap: 8px;
}

.batch-card-title::before {
  content: '';
  display: inline-block;
  width: 3px;
  height: 14px;
  background: var(--accent-blue, #2563eb);
  border-radius: 2px;
}

.batch-select-all-btn {
  padding: 8px 14px;
  background: rgba(37, 99, 235, 0.15);
  border: 1px solid rgba(37, 99, 235, 0.3);
  border-radius: 6px;
  color: #60a5fa;
  font-size: 12px;
  white-space: nowrap;
  flex-shrink: 0;
  min-height: 36px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

/* ==================== 学员选择行 ==================== */
.batch-student-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 0;
  border-bottom: 1px solid var(--bg-tertiary, #1a2d45);
  min-height: 48px;
}

.batch-student-row:last-child {
  border-bottom: none;
}

.batch-student-row:active {
  opacity: 0.85;
  background: var(--bg-tertiary, #1a2d45);
  border-radius: 6px;
  margin: 0 -6px;
  padding-left: 6px;
  padding-right: 6px;
}

/* ==================== 自定义复选框 ==================== */
.batch-checkbox {
  width: 20px;
  height: 20px;
  border-radius: 4px;
  border: 2px solid var(--text-muted, #4a5d75);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.batch-checkbox-checked {
  background: var(--accent-blue, #2563eb);
  border-color: var(--accent-blue, #2563eb);
}

.batch-checkbox-inner {
  width: 12px;
  height: 12px;
  background: #fff;
  border-radius: 1px;
}

/* ==================== 学员信息 ==================== */
.batch-student-info {
  flex: 1;
  min-width: 0;
}

.batch-student-name {
  font-size: 14px;
  font-weight: 500;
  color: var(--text-primary, #e8ecf1);
  word-break: break-word;
  overflow-wrap: break-word;
}

.batch-student-username {
  font-size: 12px;
  color: var(--text-muted, #4a5d75);
  word-break: break-word;
  overflow-wrap: break-word;
}

/* ==================== 评分表单卡片 ==================== */
.batch-score-form-card {
  margin-bottom: 12px;
}

.batch-score-form-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary, #e8ecf1);
  margin-bottom: 14px;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--bg-tertiary, #1a2d45);
  display: flex;
  align-items: center;
  gap: 8px;
}

.batch-score-form-title::before {
  content: '';
  display: inline-block;
  width: 3px;
  height: 14px;
  background: var(--accent-blue, #2563eb);
  border-radius: 2px;
}

.batch-score-hint {
  font-size: 12px;
  color: var(--text-muted, #4a5d75);
  margin-bottom: 12px;
}

/* ==================== 学员评分块 ==================== */
.batch-student-score-block {
  margin-bottom: 16px;
  padding-bottom: 14px;
  border-bottom: 1px solid var(--bg-tertiary, #1a2d45);
}

.batch-student-score-block:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.batch-student-score-title {
  font-weight: 600;
  font-size: 14px;
  color: var(--radar-green, #00d26a);
  margin-bottom: 10px;
  word-break: break-word;
  overflow-wrap: break-word;
}

/* ==================== 分类评分行 ==================== */
.batch-category-row {
  display: flex;
  align-items: center;
  margin-bottom: 10px;
  gap: 8px;
}

.batch-category-name {
  flex: 1;
  font-size: 13px;
  color: var(--text-primary, #e8ecf1);
  word-break: break-word;
  overflow-wrap: break-word;
  min-width: 0;
}

.batch-score-input {
  width: 70px;
  text-align: center;
  padding: 6px 0;
  font-size: 14px;
  font-weight: 600;
  font-family: 'SF Mono', Monaco, monospace;
  background: var(--bg-secondary, #132238);
  border: 1px solid var(--border-color, #1e3a5f);
  border-radius: 6px;
  color: var(--text-primary, #e8ecf1);
  flex-shrink: 0;
  min-height: 36px;
}

.batch-student-total {
  text-align: right;
  font-size: 14px;
  font-weight: 600;
  color: var(--radar-green, #00d26a);
  margin-top: 8px;
}

/* ==================== 无分类提示 ==================== */
.batch-no-cat-card {
  background: rgba(255, 170, 0, 0.08);
  border-color: rgba(255, 170, 0, 0.25);
  margin-bottom: 12px;
}

.batch-no-cat-text {
  font-size: 13px;
  color: var(--amber, #ffaa00);
}

/* ==================== 提交按钮 ==================== */
.batch-submit-wrap {
  margin-bottom: 12px;
}

/* ==================== 结果卡片 ==================== */
.batch-result-card {
  margin-bottom: 12px;
}

.batch-result-card--success {
  background: rgba(0, 210, 106, 0.08);
  border-color: rgba(0, 210, 106, 0.25);
}

.batch-result-card--error {
  background: rgba(255, 77, 79, 0.08);
  border-color: rgba(255, 77, 79, 0.25);
}

.batch-result-message {
  font-size: 14px;
  font-weight: 500;
}

.batch-result-card--success .batch-result-message {
  color: var(--radar-green, #00d26a);
}

.batch-result-card--error .batch-result-message {
  color: var(--alert-red, #ff4d4f);
}

.batch-result-detail {
  font-size: 12px;
  color: var(--text-secondary, #8a9bb0);
  margin-top: 4px;
  word-break: break-word;
  overflow-wrap: break-word;
}

/* ==================== 小屏适配 ==================== */
@media (max-width: 375px) {
  .batch-score-input {
    width: 60px;
    font-size: 13px;
  }
  .batch-category-name {
    font-size: 12px;
  }
  .batch-student-score-title {
    font-size: 13px;
  }
  .batch-picker-badge {
    display: none;
  }
}

@media (max-width: 320px) {
  .batch-score-input {
    width: 52px;
    padding: 5px 0;
  }
  .batch-student-score-title {
    font-size: 13px;
  }
  .batch-student-row {
    gap: 8px;
    padding: 8px 0;
  }
  .batch-student-name {
    font-size: 13px;
  }
}
