/* pages/reminders/reminders.wxss */

.reminder-card {
  margin-bottom: 10px;
}

.reminder-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 10px;
}

.reminder-name {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary, #e8ecf1);
}

.reminder-dept {
  font-size: 11px;
  color: var(--text-muted, #4a5d75);
}

.reminder-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.reminder-tag-label {
  font-weight: 600;
  margin-right: 4px;
}
