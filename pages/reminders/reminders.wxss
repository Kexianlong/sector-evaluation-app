/* pages/reminders/reminders.wxss */

.reminder-section {
  margin-bottom: 16px;
}

.reminder-section-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 10px;
  padding: 0 4px;
}

.reminder-section-title {
  font-size: 15px;
  font-weight: 700;
  color: var(--text-primary, #e8ecf1);
}

.reminder-section-count {
  font-size: 11px;
  font-weight: 600;
  color: var(--accent-blue, #2563eb);
  background: rgba(37, 99, 235, 0.15);
  border: 1px solid rgba(37, 99, 235, 0.3);
  border-radius: 10px;
  padding: 1px 8px;
  min-width: 20px;
  text-align: center;
}

.reminder-card {
  margin-bottom: 8px;
  padding: 12px 14px;
}

.reminder-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 10px;
}

.reminder-name {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary, #e8ecf1);
}

.reminder-dept {
  font-size: 11px;
  color: var(--text-muted, #4a5d75);
}

.reminder-tags {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.reminder-tag-label {
  font-weight: 600;
  margin-right: 4px;
}

.reminder-item-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.reminder-status-icon {
  font-size: 14px;
  flex-shrink: 0;
  width: 20px;
  text-align: center;
}

.reminder-item-content {
  flex: 1;
  min-width: 0;
}

.reminder-item-title {
  font-size: 14px;
  font-weight: 600;
  color: var(--text-primary, #e8ecf1);
  line-height: 1.4;
}

.reminder-item-desc {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-top: 4px;
  flex-wrap: wrap;
}

.reminder-item-sub {
  font-size: 12px;
  color: var(--text-muted, #4a5d75);
}

.reminder-status-tag {
  display: inline-block;
  padding: 1px 8px;
  border-radius: 4px;
  font-size: 11px;
  font-weight: 600;
  border: 1px solid;
}

.reminder-status-expired {
  color: var(--alert-red, #ff4d4f);
  background: rgba(255, 77, 79, 0.12);
  border-color: rgba(255, 77, 79, 0.3);
}

.reminder-status-warning {
  color: var(--amber, #ffaa00);
  background: rgba(255, 170, 0, 0.12);
  border-color: rgba(255, 170, 0, 0.3);
}

.reminder-status-normal {
  color: var(--radar-green, #00d26a);
  background: rgba(0, 210, 106, 0.1);
  border-color: rgba(0, 210, 106, 0.2);
}

.reminder-action-btn {
  flex-shrink: 0;
  padding: 5px 12px;
  border-radius: 6px;
  font-size: 12px;
  font-weight: 600;
  border: 1px solid;
  min-height: 30px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: all 0.15s;
}

.reminder-action-btn:active {
  transform: scale(0.95);
  opacity: 0.85;
}

.reminder-action-score {
  color: var(--accent-blue, #2563eb);
  background: rgba(37, 99, 235, 0.12);
  border-color: rgba(37, 99, 235, 0.3);
}

.reminder-action-edit {
  color: var(--text-secondary, #8a9bb0);
  background: var(--bg-tertiary, #1a2d45);
  border-color: var(--border-color, #1e3a5f);
}

.reminder-clickable-name {
  cursor: pointer;
  transition: color 0.15s;
}

.reminder-clickable-name:active {
  color: var(--accent-blue, #2563eb);
  opacity: 0.8;
}
