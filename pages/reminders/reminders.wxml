<view class="container">
  <view class="filter-tabs">
    <view class="filter-tab {{filter === 'all' ? 'active' : ''}}" bindtap="switchFilter" data-filter="all">全部{{totalCount > 0 ? '(' + totalCount + ')' : ''}}</view>
    <view class="filter-tab {{filter === 'expiry' ? 'active' : ''}}" bindtap="switchFilter" data-filter="expiry">证件到期{{expiryCount > 0 ? '(' + expiryCount + ')' : ''}}</view>
    <view class="filter-tab {{filter === 'scoring' ? 'active' : ''}}" bindtap="switchFilter" data-filter="scoring">评分提醒{{scoringCount > 0 ? '(' + scoringCount + ')' : ''}}</view>
  </view>

  <view wx:if="{{loadError}}" class="trend-inline-alert">
    <text>{{loadError}}</text>
    <view class="btn trend-retry-btn" bindtap="loadAllReminders">重试</view>
  </view>

  <view wx:if="{{loading}}" class="trend-skeleton-list">
    <view class="trend-skeleton-row"></view>
    <view class="trend-skeleton-row"></view>
    <view class="trend-skeleton-row"></view>
  </view>

  <block wx:if="{{!loading}}">
    <block wx:for="{{groupedReminders}}" wx:key="key">
      <view class="reminder-section">
        <view class="reminder-section-header">
          <view class="reminder-section-title">{{item.title}}</view>
          <view class="reminder-section-count">{{item.items.length}}</view>
        </view>

        <block wx:if="{{item.key === 'scoring'}}">
          <view wx:for="{{item.items}}" wx:for-item="reminder" wx:key="studentId" class="card reminder-card">
            <view class="reminder-item-row">
              <view class="reminder-status-icon">{{reminder.icon}}</view>
              <view class="reminder-item-content">
                <view class="reminder-item-title reminder-clickable-name" bindtap="goEditUser" data-userid="{{reminder.studentId}}">{{reminder.studentName}}</view>
                <view class="reminder-item-desc">
                  <text class="reminder-status-tag reminder-status-{{reminder.status}}">{{reminder.statusLabel}}</text>
                  <text wx:if="{{reminder.daysSinceLastScore !== null}}" class="reminder-item-sub">距上次评分{{reminder.daysSinceLastScore}}天（周期{{reminder.intervalDays}}天）</text>
                  <text wx:else class="reminder-item-sub">评分周期{{reminder.intervalDays}}天</text>
                </view>
              </view>
              <view class="reminder-action-btn reminder-action-score" bindtap="goScore" data-studentid="{{reminder.studentId}}" data-sectorid="{{reminder.sectorId}}">去评分</view>
            </view>
          </view>
        </block>

        <block wx:if="{{item.key === 'expiry'}}">
          <view wx:for="{{item.items}}" wx:for-item="reminder" wx:key="userId" class="card reminder-card">
            <view class="reminder-header">
              <text class="reminder-name reminder-clickable-name" bindtap="goEditUser" data-userid="{{reminder.userId}}">{{reminder.name}}</text>
              <text wx:if="{{reminder.department}}" class="reminder-dept">{{reminder.department}}</text>
            </view>
            <view class="reminder-tags">
              <view wx:if="{{reminder.icaoExpiry}}" class="reminder-item-row" style="margin-bottom:6px;">
                <view class="reminder-status-icon">{{reminder.icaoIcon}}</view>
                <view class="reminder-item-content">
                  <text class="reminder-tag-label">ICAO</text>
                  <text class="expiry-tag expiry-{{reminder.icaoStatus}}">{{reminder.icaoText}}</text>
                </view>
                <view class="reminder-action-btn reminder-action-edit" bindtap="goEditUser" data-userid="{{reminder.userId}}">编辑</view>
              </view>
              <view wx:if="{{reminder.medicalExpiry}}" class="reminder-item-row">
                <view class="reminder-status-icon">{{reminder.medicalIcon}}</view>
                <view class="reminder-item-content">
                  <text class="reminder-tag-label">体检</text>
                  <text class="expiry-tag expiry-{{reminder.medicalStatus}}">{{reminder.medicalText}}</text>
                </view>
                <view class="reminder-action-btn reminder-action-edit" bindtap="goEditUser" data-userid="{{reminder.userId}}">编辑</view>
              </view>
            </view>
          </view>
        </block>
      </view>
    </block>

    <view wx:if="{{groupedReminders.length === 0}}" class="empty-state">
      <view class="empty-icon">✅</view>
      <view class="empty-text">暂无提醒事项，一切正常</view>
    </view>
  </block>
</view>
