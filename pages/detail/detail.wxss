/* pages/detail/detail.wxss */

/* 卡片标题增强 */
.detail-card-title {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary, #e8ecf1);
  margin-bottom: 14px;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--bg-tertiary, #1a2d45);
  display: flex;
  align-items: center;
  gap: 8px;
}

.detail-card-title::before {
  content: '';
  display: inline-block;
  width: 3px;
  height: 14px;
  background: var(--accent-blue, #2563eb);
  border-radius: 2px;
}

.radar-detail-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 4px;
}

.radar-detail-left {
  flex: 1;
  padding-right: 8px;
  min-width: 0;
}

.radar-detail-name {
  font-size: 14px;
  color: var(--text-primary, #e8ecf1);
  word-break: break-word;
  overflow-wrap: break-word;
}

.radar-detail-desc {
  font-size: 12px;
  color: var(--text-secondary, #8a9bb0);
  margin-top: 2px;
  word-break: break-word;
  overflow-wrap: break-word;
}

.radar-detail-right {
  flex-shrink: 0;
  text-align: right;
}

.radar-detail-score {
  font-size: 13px;
  font-weight: 600;
  font-family: 'SF Mono', Monaco, monospace;
}

/* 小屏适配 */
@media (max-width: 375px) {
  .radar-detail-name {
    font-size: 13px;
  }
  .radar-detail-score {
    font-size: 12px;
  }
}
