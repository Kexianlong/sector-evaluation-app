/* pages/radar/radar.wxss */

/* ==================== 扇区网格（与trend页面一致） ==================== */
.trend-sector-grid {
  display: flex;
  gap: 8px;
  margin-bottom: 12px;
  flex-wrap: wrap;
}

.trend-sector-grid .sector-card {
  flex: 1;
  min-width: 60px;
  max-width: 120px;
}

.sector-card {
  flex: 1;
  text-align: center;
  padding: 10px 0;
  background: #1a2d45;
  border: 1px solid #1e3a5f;
  border-radius: 8px;
}

.sector-card.active {
  border-color: #2563eb !important;
  background: linear-gradient(135deg, #1e3a5f, #132238) !important;
  box-shadow: 0 0 12px rgba(37, 99, 235, 0.25);
}

.trend-sector-title {
  font-weight: 700;
  font-size: 15px;
  font-family: monospace;
}

.trend-sector-subtitle {
  font-size: 10px;
  margin-top: 2px;
}

/* ==================== 弹窗 ==================== */
.popup-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(10, 22, 40, 0.85);
  z-index: 10001;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
}

.popup-content {
  background: var(--bg-secondary);
  width: 100%;
  max-height: 70vh;
  border-radius: 16px 16px 0 0;
  padding: 20px;
  padding-bottom: calc(20px + env(safe-area-inset-bottom));
  box-sizing: border-box;
  overflow-y: auto;
  border-top: 1px solid var(--border-color);
  box-shadow: 0 -4px 24px rgba(0, 0, 0, 0.4);
}

/* ==================== 工具栏 ==================== */
.radar-toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
  gap: 8px;
  padding: 12px 16px;
  background: linear-gradient(135deg, var(--bg-secondary, #132238), rgba(15, 29, 48, 0.95));
  border-radius: 8px;
  border: 1px solid var(--border-color, #1e3a5f);
  position: relative;
  overflow: hidden;
}

.radar-toolbar::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(90deg, rgba(59, 130, 246, 0.5), rgba(59, 130, 246, 0.1), transparent);
}

.radar-student-select {
  font-size: 12px;
  color: var(--accent-blue);
  padding: 6px 12px;
  border: 1px solid rgba(37, 99, 235, 0.2);
  border-radius: 6px;
  background: rgba(37, 99, 235, 0.06);
  white-space: nowrap;
  flex-shrink: 0;
  min-height: 32px;
  display: inline-flex;
  align-items: center;
}

/* ==================== 分数卡片 ==================== */
.radar-score-card {
  text-align: center;
  padding: 24px 20px;
  background: linear-gradient(135deg, var(--bg-secondary), var(--bg-primary));
  border: 1px solid var(--border-color);
  margin-bottom: 12px;
  border-radius: 8px;
}

.radar-score-title {
  font-size: 12px;
  color: var(--text-secondary);
  letter-spacing: 2px;
}

.radar-score-value {
  font-size: 48px;
  font-weight: 800;
  margin: 8px 0;
  font-family: 'SF Mono', Monaco, monospace;
  letter-spacing: 2px;
}

.radar-score-no-data {
  background: rgba(255,255,255,0.05);
  color: var(--text-muted);
  border: 1px solid rgba(255,255,255,0.1);
}

.radar-score-meta {
  font-size: 11px;
  color: var(--text-muted);
  margin-top: 10px;
  font-family: 'SF Mono', Monaco, monospace;
}

.radar-rank-info {
  font-size: 12px;
  color: var(--accent-cyan);
  margin-top: 6px;
  font-family: 'SF Mono', Monaco, monospace;
  font-weight: 600;
}

.radar-score-hint {
  font-size: 11px;
  color: var(--text-muted);
  margin-top: 8px;
  opacity: 0.7;
}

.radar-score-card:active {
  opacity: 0.9;
  transform: scale(0.99);
}

/* ==================== 图表区域 ==================== */
.radar-chart-card {
  padding: 16px;
  margin-bottom: 12px;
}

.radar-chart-fallback {
  padding: 12px 8px;
  color: var(--text-muted) !important;
  font-size: 13px;
  text-align: center;
}

/* ==================== 评分明细行 ==================== */
.radar-score-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid var(--bg-tertiary);
  min-height: 48px;
}
.radar-score-row:last-child { border-bottom: none; }
.radar-score-row:active { background: var(--bg-tertiary); border-radius: 6px; }
.radar-history-active {
  background: rgba(37, 99, 235, 0.12) !important;
  border-radius: 6px;
  border-left: 3px solid #2563eb;
  padding-left: 9px;
}

.radar-score-left { flex: 1; padding-right: 8px; min-width: 0; }
.radar-score-name { font-size: 14px; color: var(--text-primary); word-break: break-word; overflow-wrap: break-word; }
.radar-score-max { font-size: 11px; color: var(--text-muted); margin-top: 2px; }
.radar-score-right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }

.radar-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}
.radar-popup-title { font-size: 16px; font-weight: 700; color: var(--text-primary); }
.radar-popup-close {
  min-width: 40px; min-height: 40px;
  border: 1px solid var(--border-color);
  border-radius: 8px;
  background: var(--bg-tertiary);
  font-size: 20px; line-height: 1;
  color: var(--text-muted);
  display: inline-flex; align-items: center; justify-content: center;
  padding: 0;
}
.radar-popup-close:active { background: var(--border-color); color: var(--text-primary); }

.radar-detail-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 4px;
}
.radar-detail-row:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
.radar-detail-left { flex: 1; padding-right: 8px; min-width: 0; }
.radar-detail-name { font-size: 14px; color: var(--text-primary); word-break: break-word; overflow-wrap: break-word; }
.radar-detail-desc { font-size: 11px; color: var(--text-muted); margin-top: 2px; word-break: break-word; overflow-wrap: break-word; }
.radar-detail-deduct { font-size: 11px; color: var(--danger, #ef4444); margin-top: 2px; word-break: break-word; overflow-wrap: break-word; font-weight: 600; }
.radar-detail-right { flex-shrink: 0; text-align: right; display: flex; align-items: center; gap: 6px; }
.radar-detail-score { font-size: 13px; font-weight: 600; font-family: 'SF Mono', Monaco, monospace; }

/* 扣分项红色突出显示 */
.radar-detail-item--danger {
  border-left: 3px solid var(--alert-red, #ff4d4f) !important;
  background: rgba(255, 77, 79, 0.08) !important;
  border-radius: 6px;
  padding: 10px 8px !important;
  margin-bottom: 6px;
}
.radar-detail-item--danger:active {
  background: rgba(255, 77, 79, 0.15) !important;
}
.radar-detail-reason {
  margin-top: 6px;
  padding: 8px 10px;
  border-radius: 6px;
  background: rgba(239, 68, 68, 0.12);
  border-left: 3px solid var(--danger, #ef4444);
  font-size: 12px;
  color: #ff8585;
  line-height: 1.6;
  font-weight: 500;
}
.radar-detail-reason-empty {
  color: var(--text-muted);
  font-style: italic;
}

/* ==================== 维度历史趋势 ==================== */
.radar-cat-trend-section {
  padding: 10px 0;
  border-bottom: 1px solid var(--border-color, #1e3a5f);
  margin-bottom: 8px;
}
.radar-cat-trend-title {
  font-size: 12px;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 8px;
}
.radar-cat-trend-row {
  display: flex;
  align-items: flex-end;
  gap: 8px;
  height: 80px;
  padding: 0 4px;
}
.radar-cat-trend-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
  min-width: 0;
}
.radar-cat-trend-bar-wrap {
  width: 100%;
  max-width: 28px;
  height: 50px;
  background: var(--bg-primary, #0a1628);
  border-radius: 3px;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  overflow: hidden;
}
.radar-cat-trend-bar {
  width: 100%;
  border-radius: 3px 3px 0 0;
  transition: height 0.3s;
  min-height: 2px;
}
.radar-cat-trend-score {
  font-size: 10px;
  font-weight: 600;
  font-family: 'SF Mono', Monaco, monospace;
}
.radar-cat-trend-date {
  font-size: 9px;
  color: var(--text-muted);
}

.radar-cat-trend-item:active {
  opacity: 0.7;
}

.radar-cat-trend-item--active .radar-cat-trend-bar-wrap {
  box-shadow: 0 0 0 2px var(--accent-blue, #60a5fa);
}

.radar-cat-trend-detail {
  margin-top: 10px;
  padding: 10px 12px;
  background: var(--bg-surface-2, #162033);
  border-radius: 8px;
  border: 1rpx solid var(--border-subtle, #1a2740);
}

.radar-cat-trend-detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 5px 0;
  border-bottom: 1rpx solid var(--divider, #1a2740);
}

.radar-cat-trend-detail-row:last-child {
  border-bottom: none;
}

.radar-cat-trend-detail-label {
  font-size: 12px;
  color: var(--text-secondary);
}

.radar-cat-trend-detail-value {
  font-size: 13px;
  font-weight: 600;
  color: var(--text-primary);
  font-family: 'SF Mono', Monaco, monospace;
}

/* ==================== 个人到期提醒横幅 ==================== */
.personal-reminder-banner {
  margin-bottom: 12px;
  border-radius: 8px;
  overflow: hidden;
}
.personal-reminder-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 14px;
  font-size: 13px;
  line-height: 1.5;
}
.personal-reminder-expired {
  background: rgba(255, 77, 79, 0.08);
  border: 1px solid rgba(255, 77, 79, 0.2);
  color: #ff4d4f;
  border-radius: 8px;
  margin-bottom: 6px;
}
.personal-reminder-warning {
  background: rgba(255, 170, 0, 0.08);
  border: 1px solid rgba(255, 170, 0, 0.2);
  color: #ffaa00;
  border-radius: 8px;
  margin-bottom: 6px;
}
.personal-reminder-icon {
  flex-shrink: 0;
  font-size: 14px;
}
.personal-reminder-text {
  flex: 1;
  color: var(--text-primary, #e8ecf1);
}
.personal-reminder-action {
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 4px;
  background: rgba(255, 255, 255, 0.08);
  white-space: nowrap;
  flex-shrink: 0;
}

/* ==================== 对比趋势标记 ==================== */
.radar-comparison-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin-top: 8px;
}
.radar-comparison-trend {
  font-size: 13px;
  font-weight: 600;
  font-family: 'SF Mono', Monaco, monospace;
}
.radar-comparison-label {
  font-size: 13px;
  color: var(--text-secondary, #8a9bb0);
}
.radar-trend-up {
  color: #00d26a;
}
.radar-trend-down {
  color: #ff4d4f;
}
.radar-trend-flat {
  color: var(--text-secondary, #8a9bb0);
}
.radar-cat-trend {
  font-size: 12px;
  font-weight: 600;
  font-family: 'SF Mono', Monaco, monospace;
}

/* ==================== 退出登录按钮 ==================== */
.manager-logout-btn {
  width: 100%;
  margin: 16px 0 24px 0;
  padding: 12px 16px;
  text-align: center;
  color: var(--alert-red, #ff4d4f);
  font-size: 13px;
  border: 1px solid rgba(255, 77, 79, 0.2);
  border-radius: 8px;
  background: rgba(255, 77, 79, 0.05);
}
.manager-logout-btn:active {
  background: rgba(255, 77, 79, 0.1);
}