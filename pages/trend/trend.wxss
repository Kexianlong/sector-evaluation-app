/* pages/trend/trend.wxss */

/* ==================== 工具栏 ==================== */
.trend-toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
  flex-wrap: wrap;
  gap: 8px;
}

.trend-user-meta {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  color: var(--text-primary, #e8ecf1);
}

.trend-user-name {
  font-weight: 600;
}

.trend-student-select {
  display: inline-flex;
  align-items: center;
  font-size: 12px;
  color: #60a5fa;
  padding: 6px 12px;
  border: 1px solid rgba(37, 99, 235, 0.25);
  border-radius: 6px;
  background: rgba(37, 99, 235, 0.08);
  min-height: 32px;
}

.trend-page-note {
  font-size: 12px;
  color: var(--text-muted, #4a5d75);
  line-height: 1.4;
}

/* ==================== 扇区网格 ==================== */
.trend-sector-grid {
  display: flex;
  gap: 8px;
  margin-bottom: 12px;
  flex-wrap: wrap;
}

.trend-sector-grid .sector-card {
  flex: 1;
  min-width: 60px;
  max-width: 120px;
}

.sector-card {
  flex: 1;
  text-align: center;
  padding: 10px 0;
  background: #1a2d45;
  border: 1px solid #1e3a5f;
  border-radius: 8px;
}

.sector-card.active {
  border-color: #2563eb !important;
  background: linear-gradient(135deg, #1e3a5f, #132238) !important;
  box-shadow: 0 0 12px rgba(37, 99, 235, 0.25);
}

.trend-sector-title {
  font-weight: 700;
  font-size: 15px;
  font-family: monospace;
}

.trend-sector-subtitle {
  font-size: 10px;
  margin-top: 2px;
}

/* ==================== 迷你雷达图容器 ==================== */
.trend-overview-radar {
  margin-bottom: 12px;
}

.trend-overview-radar canvas {
  display: block;
  border-radius: 8px;
}

/* ==================== 评分徽章 ==================== */
.score-badge {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 12px;
  font-weight: 600;
  font-family: 'SF Mono', Monaco, monospace;
}

.score-excellent {
  background: rgba(0, 210, 106, 0.15);
  color: var(--radar-green, #00d26a);
  border: 1px solid rgba(0, 210, 106, 0.3);
}

.score-good {
  background: rgba(255, 170, 0, 0.15);
  color: var(--amber, #ffaa00);
  border: 1px solid rgba(255, 170, 0, 0.3);
}

.score-pass {
  background: rgba(37, 99, 235, 0.15);
  color: #60a5fa;
  border: 1px solid rgba(37, 99, 235, 0.3);
}

.score-fail {
  background: rgba(255, 77, 79, 0.15);
  color: var(--alert-red, #ff4d4f);
  border: 1px solid rgba(255, 77, 79, 0.3);
}

.trend-grade-text {
  font-size: 11px;
  color: var(--text-muted, #4a5d75);
  margin-top: 4px;
  text-align: center;
}

/* ==================== 内联错误提示 ==================== */
.trend-inline-alert {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  margin-bottom: 10px;
  padding: 10px 12px;
  border-radius: 6px;
  background: rgba(255, 170, 0, 0.12);
  border: 1px solid rgba(255, 170, 0, 0.24);
  color: #fbbf24;
  font-size: 12px;
}

.trend-retry-btn {
  padding: 4px 10px;
  border: 1px solid rgba(255, 170, 0, 0.3);
  border-radius: 6px;
  background: rgba(255, 170, 0, 0.14);
  color: #fbbf24;
  font-size: 12px;
  flex-shrink: 0;
}

/* ==================== 加载状态 ==================== */
.trend-loading-state {
  margin-bottom: 8px;
  padding: 8px 10px;
  border-radius: 6px;
  border: 1px solid rgba(37, 99, 235, 0.25);
  background: rgba(37, 99, 235, 0.08);
  color: #93c5fd;
  font-size: 12px;
  text-align: center;
}

.trend-skeleton-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.trend-skeleton-row {
  height: 44px;
  border-radius: 6px;
  background: linear-gradient(90deg, rgba(26, 45, 69, 0.65), rgba(36, 63, 97, 0.65), rgba(26, 45, 69, 0.65));
  background-size: 200% 100%;
  animation: trendShimmer 1.2s linear infinite;
}

@keyframes trendShimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ==================== 空状态 ==================== */
.empty-state {
  text-align: center;
  padding: 32px 0;
}

.empty-text {
  color: #4a5d75;
  font-size: 13px;
}

/* ==================== 学员详情弹窗 ==================== */
.trend-detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(10, 22, 40, 0.85);
  z-index: 1000;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.trend-detail-popup {
  background: var(--bg-secondary, #132238);
  max-height: 80vh;
  border-radius: 16px 16px 0 0;
  padding: 16px;
  overflow-y: auto;
  border-top: 1px solid var(--border-color, #1e3a5f);
  box-shadow: 0 -4px 24px rgba(0, 0, 0, 0.4);
  animation: slideUp 0.25s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.trend-detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.trend-detail-title {
  font-size: 16px;
  font-weight: 700;
  color: var(--text-primary, #e8ecf1);
}

.trend-detail-close {
  font-size: 20px;
  color: var(--text-muted, #4a5d75);
  padding: 4px 8px;
}

.detail-mini-radar {
  width: 100%;
  height: 200px;
  margin: 8px 0 12px;
}
