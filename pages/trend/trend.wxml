<view class="container">
  <!-- 用户信息栏 -->
  <view class="trend-toolbar">
    <view class="trend-user-meta">
      <image wx:if="{{avatarUrl}}" class="trend-avatar" src="{{avatarUrl}}" mode="aspectFill" />
      <view class="trend-user-text">
        <view class="trend-user-name-row">
          <text class="trend-user-name">{{userInfo.name || '未登录'}}</text>
          <text wx:if="{{roleLabel}}" class="identity-badge identity-badge-role">{{roleLabel}}</text>
          <text wx:if="{{levelLabel}}" class="identity-badge identity-badge-level">{{levelLabel}}</text>
        </view>
        <view class="trend-page-note">{{isInstructor ? '全员最近一次评分总览' : '历次评估记录（最近在前）'}}</view>
      </view>
    </view>
  </view>

  <!-- 扇区切换 -->
  <view class="trend-sector-grid">
    <view wx:for="{{sectors}}" wx:key="id"
          class="sector-card {{currentSector === item.id ? 'active' : ''}}"
          bindtap="switchSector" data-sector="{{item.id}}">
      <view class="trend-sector-title">{{item.name}}</view>
      <view class="trend-sector-subtitle">扇区</view>
    </view>
  </view>

  <!-- 学员评分总览卡片 -->
  <view class="card">
    <view class="card-title">{{isInstructor ? '学员最近一次评分（含扣分项）' : '我的全部评估记录'}}</view>

    <!-- 错误提示 -->
    <view wx:if="{{loadError}}" class="trend-inline-alert">
      <text>{{loadError}}</text>
      <view bindtap="onRetryLoad" class="trend-retry-btn">重试</view>
    </view>

    <!-- 加载中 -->
    <view wx:if="{{loading}}" class="trend-loading-state">正在加载趋势数据...</view>
    <view wx:if="{{loading}}" class="trend-skeleton-list">
      <view class="trend-skeleton-row" />
      <view class="trend-skeleton-row" />
      <view class="trend-skeleton-row" />
    </view>

    <!-- 学员卡片列表 -->
    <view wx:for="{{trendData}}" wx:key="idx" wx:for-item="record" wx:for-index="idx" wx:if="{{!loading}}">
      <view class="trend-student-overview">
        <view class="trend-student-overview-head">
          <view>
            <view class="trend-overview-name" style="{{isInstructor ? 'text-decoration: underline dotted; color: #60a5fa;' : ''}}" data-studentid="{{record.studentId}}" data-name="{{record.studentName}}" bindtap="{{isInstructor ? 'showStudentDetail' : ''}}">{{record.studentName || '未命名学员'}}</view>
            <view class="trend-overview-meta">{{record.date}} · {{currentSector}} 扇区</view>
          </view>
          <view class="trend-overview-score-wrap">
            <text class="score-badge {{record.gradeClass}}" style="display:inline-block;text-align:center;">{{record.totalScore}}</text>
            <view class="trend-grade-text">{{record.grade}}</view>
          </view>
        </view>
        <view class="trend-student-overview-body">
          <view class="trend-overview-radar">
            <canvas type="2d" id="miniRadar_{{idx}}" style="width:100%;height:180px;"></canvas>
          </view>
          <view class="trend-overview-deducts">
            <view class="trend-overview-deduct-title">扣分项</view>
            <block wx:if="{{record.computedDeductItems && record.computedDeductItems.length > 0}}">
              <view wx:for="{{record.computedDeductItems}}" wx:for-item="deduct" wx:key="itemId" class="trend-overview-deduct-item">
                <view class="trend-overview-deduct-name">{{deduct.itemName}}</view>
                <view class="trend-overview-deduct-meta">扣 {{deduct.deduct}} 分（{{deduct.score}}/{{deduct.maxScore}}）</view>
                <view wx:if="{{deduct.reason}}" class="trend-overview-deduct-reason">{{deduct.reason}}</view>
              </view>
            </block>
            <view wx:if="{{!record.computedDeductItems || record.computedDeductItems.length === 0}}" class="trend-overview-deduct-empty">无扣分项</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{!loading && trendData.length === 0}}" class="empty-state">
      <view class="empty-text">当前扇区暂无学员评分数据</view>
    </view>
  </view>

  <!-- 学员历史评分详情弹窗 -->
  <view wx:if="{{detailStudent}}" class="trend-detail-mask" bindtap="closeStudentDetail">
    <view class="trend-detail-popup" catchtap="preventBubble">
      <!-- 头部 -->
      <view class="trend-detail-header">
        <view class="trend-detail-title">{{detailStudent.studentName}} 的历史评分</view>
        <view class="trend-detail-close" bindtap="closeStudentDetail">×</view>
      </view>

      <!-- 统计卡片 -->
      <view class="stat-grid {{detailLoading ? 'stat-grid-dim' : ''}}">
        <view class="stat-card">
          <view class="stat-value">{{detailLoading ? '—' : studentHistory.length}}</view>
          <view class="stat-label">评估次数</view>
        </view>
        <view class="stat-card">
          <view class="stat-value">{{detailLoading ? '—' : avgScore}}</view>
          <view class="stat-label">平均分</view>
        </view>
        <view class="stat-card">
          <view class="stat-value" style="font-size:14px;font-weight:600;color:var(--text-primary);">{{detailLoading ? '—' : bestSector}}</view>
          <view class="stat-label">最佳扇区</view>
        </view>
        <view class="stat-card">
          <view class="stat-value" style="font-size:14px;font-weight:600;color:var(--amber);">{{detailLoading ? '—' : bestGrade}}</view>
          <view class="stat-label">最高等级</view>
        </view>
      </view>

      <!-- 评估历史 -->
      <view class="card" style="margin-bottom:0;">
        <view class="card-title">评估历史</view>
        <view wx:if="{{detailLoading}}" class="trend-loading-state">数据加载中...</view>
        <view wx:if="{{!detailLoading && studentHistory.length === 0}}" class="empty-state empty-state-compact">
          <view class="empty-text">暂无评估记录</view>
        </view>
        <view wx:for="{{studentHistory}}" wx:key="id" wx:if="{{!detailLoading}}">
          <view class="student-history-block">
            <view class="student-history-toggle {{detailExpandedId === item.id ? 'student-history-toggle-open' : ''}}" bindtap="toggleDetailExpand" data-id="{{item.id}}">
              <view class="student-history-row-head">
                <view>
                  <view class="list-item-title">{{item.sectorName || '扇区'}}</view>
                  <view class="list-item-sub">{{item.date}}</view>
                </view>
                <text wx:if="{{item.grade}}" class="score-badge {{item.gradeClass || 'score-pass'}}">{{item.grade}}</text>
              </view>
              <text class="list-item-arrow">{{detailExpandedId === item.id ? '▼' : '▶'}}</text>
            </view>

            <view wx:if="{{detailExpandedId === item.id}}" class="student-history-panel">
              <view class="student-history-total-row">
                <text class="student-history-total-label">总分</text>
                <text class="student-history-total-value">
                  {{item.total}}
                  <text class="student-history-total-max"> / {{item.maxTotal}}</text>
                </text>
              </view>

              <!-- 雷达图 -->
              <canvas wx:if="{{item.computedScores && item.computedScores.length >= 3}}" type="2d" id="detailRadar_{{item.id}}" class="detail-mini-radar"></canvas>

              <view wx:for="{{item.scorePairs}}" wx:for-item="row" wx:key="name" style="display:flex;justify-content:space-between;padding:6px 0;align-items:center;">
                <text style="flex:1;padding-right:8px;font-size:12px;color:var(--text-primary);">{{row.name}}</text>
                <text style="font-size:12px;font-family:monospace;color:#60a5fa;">{{row.score}}</text>
              </view>

              <view wx:if="{{item.deductItems && item.deductItems.length > 0}}" style="margin-top:8px;">
                <view
                  wx:for="{{item.deductItems}}"
                  wx:for-item="d"
                  wx:key="itemId"
                  class="trend-overview-deduct-item mygrades-deduct-item"
                  bindtap="toggleDetailDeductExpand"
                  data-key="{{d.deductKey}}"
                >
                  <view style="display:flex;justify-content:space-between;align-items:center;">
                    <view>
                      <view class="trend-overview-deduct-name">{{d.itemName}}</view>
                      <view class="trend-overview-deduct-meta">扣 {{d.deductVal}} 分（{{d.itemScore}}/{{d.itemMax}}）</view>
                    </view>
                    <text style="font-size:11px;color:var(--text-muted);margin-left:8px;">{{detailExpandedDeductId === d.deductKey ? '▼' : '▶'}}</text>
                  </view>
                  <view wx:if="{{detailExpandedDeductId === d.deductKey && d.reason}}" class="trend-overview-deduct-reason mygrades-deduct-reason">{{d.reason}}</view>
                  <view wx:if="{{detailExpandedDeductId === d.deductKey && !d.reason}}" class="trend-overview-deduct-empty">未填写扣分说明</view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
