.page-container {
  padding: 24rpx;
  min-height: 100vh;
  background: var(--bg-page, #070d17);
}
.result-header {
  text-align: center;
  padding: 40rpx 0 20rpx;
}
.result-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}
.result-title {
  font-size: 36rpx;
  color: var(--text-primary, #e2e8f0);
  font-weight: 600;
}
.score-display {
  text-align: center;
  padding: 32rpx 24rpx;
}
.score-value {
  font-size: 80rpx;
  font-weight: 700;
  color: var(--text-primary, #e2e8f0);
  line-height: 1;
}
.score-grade {
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 12rpx;
}
.score-comparison {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}
.deduction-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-subtle, #1a2740);
}
.result-actions {
  display: flex;
  gap: 20rpx;
  padding: 32rpx 0;
}
.result-actions .btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
}
