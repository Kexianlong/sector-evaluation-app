<view class="container">
  <!-- 用户信息栏 -->
  <view class="manager-profile-bar" bindtap="goToProfile">
    <image class="manager-avatar" src="{{avatarUrl}}" mode="aspectFill" />
    <view class="manager-profile-meta">
      <view class="manager-profile-name">
        <text class="trend-user-name">{{userInfo.name || '未登录'}}</text>
        <text wx:if="{{roleLabel}}" class="identity-badge identity-badge-role">{{roleLabel}}</text>
        <text wx:if="{{levelLabel}}" class="identity-badge identity-badge-level">{{levelLabel}}</text>
      </view>
      <view wx:if="{{departmentLabel}}" class="manager-profile-dept">{{departmentLabel}}</view>
    </view>
    <text class="list-item-arrow" style="margin-left:auto;">›</text>
  </view>

  <!-- 退出登录 -->
  <view class="manager-logout-btn" bindtap="logout">退出登录</view>

  <!-- 管理端到期提醒 -->
  <view class="reminder-bar" wx:if="{{managerReminder}}" bindtap="expandReminderPanel">
    <text class="reminder-bar-icon">⚠</text>
    <text class="reminder-bar-text">{{managerReminder}}</text>
    <text class="reminder-bar-action">查看详情</text>
  </view>

  <!-- 错误提示 -->
  <view wx:if="{{loadError}}" class="trend-inline-alert" style="margin-bottom:12px;">
    <text>{{loadError}}</text>
    <view class="btn trend-retry-btn" bindtap="onRetryLoad">重试</view>
  </view>

  <!-- 统计卡片 -->
  <view wx:if="{{userInfo.role !== 'student'}}" class="manager-stat-strip {{loading ? 'stat-grid-dim' : ''}}">
    <view class="manager-stat-box manager-stat-box--green">
      <view class="manager-stat-box-label">学员</view>
      <view class="manager-stat-box-value">{{loading ? '—' : stats.student}}</view>
    </view>
    <view class="manager-stat-box manager-stat-box--amber">
      <view class="manager-stat-box-label">教员</view>
      <view class="manager-stat-box-value">{{loading ? '—' : stats.instructor}}</view>
    </view>
    <view class="manager-stat-box manager-stat-box--red">
      <view class="manager-stat-box-label">待评分</view>
      <view class="manager-stat-box-value">{{loading ? '—' : pendingTasks}}</view>
    </view>
    <view class="manager-stat-box manager-stat-box--blue">
      <view class="manager-stat-box-label">本月已评</view>
      <view class="manager-stat-box-value">{{loading ? '—' : scoreStats.totalScores}}</view>
    </view>
  </view>

  <!-- 待关注事项 -->
  <view class="card mb-12" wx:if="{{attentionItems.length}}">
    <view class="card-title">待关注事项</view>
    <view wx:for="{{attentionItems}}" wx:key="id" class="attention-item" bindtap="{{item.action}}" data-params="{{item.params}}">
      <text class="attention-icon">{{item.icon}}</text>
      <view class="attention-content">
        <text class="text-primary text-14">{{item.text}}</text>
        <text class="text-secondary text-12">{{item.subtext}}</text>
      </view>
      <text class="attention-arrow">›</text>
    </view>
  </view>

  <!-- 待处理事项 -->
  <view wx:if="{{isManager && actionItems.length > 0}}" class="card" style="margin-bottom:12px;">
    <view class="card-title">待处理事项</view>
    <view wx:for="{{actionItems}}" wx:key="id" class="action-item-row" bindtap="{{item.action}}" data-studentid="{{item.studentId}}" data-userid="{{item.userId}}">
      <text class="action-item-dot {{item.level}}"></text>
      <view class="action-item-content">
        <text class="action-item-text">{{item.text}}</text>
        <text class="action-item-sub">{{item.sub}}</text>
      </view>
      <text class="list-item-arrow">›</text>
    </view>
  </view>

  <!-- 到期提醒面板 -->
  <view wx:if="{{isManager && (reminderStats.icaoExpired + reminderStats.icaoWarning + reminderStats.medicalExpired + reminderStats.medicalWarning > 0)}}" class="card reminder-summary-card" style="margin-bottom:12px;">
    <view class="card-title" bindtap="toggleReminders">
      <text style="color:#ff4d4f;">⚠</text> 到期提醒
      <text style="font-size:12px;font-weight:400;color:#8a9bb0;margin-left:8px;">
        <text wx:if="{{reminderStats.icaoExpired + reminderStats.medicalExpired > 0}}" style="color:#ff4d4f;">{{reminderStats.icaoExpired + reminderStats.medicalExpired}}人已过期</text>
        <text wx:if="{{reminderStats.icaoWarning + reminderStats.medicalWarning > 0}}" style="color:#ffaa00;margin-left:6px;">{{reminderStats.icaoWarning + reminderStats.medicalWarning}}人即将到期</text>
      </text>
      <text style="margin-left:auto;font-size:12px;color:#4a5d75;">{{showReminders ? '收起 ▲' : '展开 ▼'}}</text>
    </view>
    <view wx:if="{{showReminders}}" class="reminder-list">
      <view wx:for="{{reminders}}" wx:key="userId" wx:if="{{index < 10}}" class="reminder-item">
        <view class="reminder-item-header">
          <text style="font-weight:600;color:#e8ecf1;">{{item.name}}</text>
          <text wx:if="{{item.department}}" style="font-size:11px;color:#4a5d75;margin-left:4px;">{{item.department}}</text>
        </view>
        <view class="reminder-item-tags">
          <view wx:if="{{item.icao.status === 'warning' || item.icao.status === 'expired'}}" class="expiry-tag expiry-{{item.icao.status}}">
            ICAO: {{item.icao.message}}
          </view>
          <view wx:if="{{item.medical.status === 'warning' || item.medical.status === 'expired'}}" class="expiry-tag expiry-{{item.medical.status}}">
            体检: {{item.medical.message}}
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 管理功能 -->
  <view wx:if="{{isManager}}" class="card manager-admin-card" style="margin-bottom:12px;">
    <view class="card-title">管理功能</view>
    <view class="admin-grid">
      <view class="admin-grid-tile" data-action="users" hover-class="admin-grid-tile--active" bindtap="onAdminGridTap">
        <image class="admin-grid-icon" src="/images/icons/user.svg" mode="aspectFit" />
        <text class="admin-grid-label">用户管理</text>
      </view>
      <view class="admin-grid-tile" data-action="config" hover-class="admin-grid-tile--active" bindtap="onAdminGridTap">
        <image class="admin-grid-icon" src="/images/icons/gear.svg" mode="aspectFit" />
        <text class="admin-grid-label">扇区配置</text>
      </view>
      <view class="admin-grid-tile" data-action="scoreConfig" hover-class="admin-grid-tile--active" bindtap="onAdminGridTap">
        <image class="admin-grid-icon" src="/images/icons/clipboard.svg" mode="aspectFit" />
        <text class="admin-grid-label">评分配置</text>
      </view>
      <view class="admin-grid-tile" data-action="analysis" hover-class="admin-grid-tile--active" bindtap="onAdminGridTap">
        <image class="admin-grid-icon" src="/images/icons/chart.svg" mode="aspectFit" />
        <text class="admin-grid-label">评估记录</text>
      </view>
      <view class="admin-grid-tile" data-action="reminders" hover-class="admin-grid-tile--active" bindtap="onAdminGridTap">
        <image class="admin-grid-icon" src="/images/icons/bell.svg" mode="aspectFit" />
        <text class="admin-grid-label">全局提醒</text>
      </view>
      <view class="admin-grid-tile" data-action="export" hover-class="admin-grid-tile--active" bindtap="onAdminGridTap">
        <image class="admin-grid-icon" src="/images/icons/download.svg" mode="aspectFit" />
        <text class="admin-grid-label">数据导出</text>
      </view>
    </view>
  </view>

</view>