.student-profile-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx;
}
.student-profile-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.student-profile-info {
  flex: 1;
}
.student-profile-name {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}
.student-profile-meta {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 4rpx;
}
.card-alert {
  background: rgba(245, 158, 11, 0.1);
  border: 1rpx solid rgba(245, 158, 11, 0.3);
}
.expiring-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--border-subtle);
}
.expiring-row:last-child {
  border-bottom: none;
}
.expiring-urgent {
  background: rgba(239, 68, 68, 0.08);
}
.expiring-icon {
  font-size: 24rpx;
}
.expiring-label {
  font-size: 24rpx;
  color: var(--text-primary);
  flex: 1;
}
.expiring-date {
  font-size: 22rpx;
  color: var(--text-muted);
  font-family: 'SF Mono', Monaco, monospace;
}
.tab-bar {
  display: flex;
  background: var(--surface);
  border-radius: 16rpx;
  padding: 4rpx;
  margin-bottom: 16rpx;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: var(--text-secondary);
  border-radius: 12rpx;
  transition: all 0.2s;
}
.tab-active {
  background: var(--primary);
  color: #fff;
  font-weight: 600;
}
.recent-score-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-subtle);
}
.recent-score-row:last-child {
  border-bottom: none;
}
.recent-score-left {
  flex: 1;
}
.recent-score-sector {
  font-size: 26rpx;
  color: var(--text-primary);
  display: block;
}
.recent-score-date {
  font-size: 22rpx;
  color: var(--text-muted);
  display: block;
  margin-top: 4rpx;
}
.recent-score-right {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}
.recent-score-total {
  font-size: 32rpx;
  font-weight: 700;
  font-family: 'SF Mono', Monaco, monospace;
}
.recent-score-grade {
  font-size: 22rpx;
  color: var(--text-muted);
}
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-subtle);
}
.info-row:last-child {
  border-bottom: none;
}
.info-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}
.info-value {
  font-size: 26rpx;
  color: var(--text-primary);
  font-family: 'SF Mono', Monaco, monospace;
}
.student-profile-actions {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 0;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}
.student-profile-actions .btn {
  flex: 1;
}

/* ==================== 扇区评分曲线图 ==================== */
.sector-trend-container {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.sector-trend-card {
  padding: 24rpx;
}

.sector-trend-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.sector-trend-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.sector-trend-count {
  font-size: 22rpx;
  color: var(--text-muted);
}

.sector-trend-canvas-wrap {
  width: 100%;
  margin: 16rpx 0;
}

.sector-trend-canvas {
  width: 100%;
  height: 160px;
}

.sector-trend-summary {
  display: flex;
  justify-content: space-around;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border-subtle);
  margin-top: 8rpx;
}

.sector-trend-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.sector-trend-stat .stat-label {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: 4rpx;
}

.sector-trend-stat .stat-value {
  font-size: 28rpx;
  font-weight: 700;
  font-family: 'SF Mono', Monaco, monospace;
  color: var(--text-primary);
}

.sector-trend-stat .stat-high {
  color: #22c55e;
}

.sector-trend-stat .stat-low {
  color: #ef4444;
}

/* 日期标签 */
.sector-trend-dates {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 16rpx 0 8rpx;
  border-top: 1rpx solid var(--border-subtle);
  margin-top: 8rpx;
}

.sector-trend-date-tag {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 16rpx;
  background: rgba(59, 130, 246, 0.1);
  border: 1rpx solid rgba(59, 130, 246, 0.2);
  border-radius: 8rpx;
  min-width: 80rpx;
}

.sector-trend-date-text {
  font-size: 20rpx;
  color: var(--text-muted);
}

.sector-trend-date-score {
  font-size: 24rpx;
  color: #3b82f6;
  font-weight: 600;
  font-family: 'SF Mono', Monaco, monospace;
}
