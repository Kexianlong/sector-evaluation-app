/* pages/profile/profile.wxss */

/* ==================== 顶部卡片 ==================== */
.profile-header-card {
  padding: 20px 16px;
}

.profile-header {
  display: flex;
  align-items: center;
  gap: 16px;
}

.profile-avatar {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  border: 2px solid var(--border-color, #1e3a5f);
  flex-shrink: 0;
  background: var(--bg-tertiary, #1a2d45);
}

.profile-header-info {
  flex: 1;
  min-width: 0;
}

.profile-name {
  font-size: 18px;
  font-weight: 700;
  color: var(--text-primary, #e8ecf1);
  margin-bottom: 8px;
}

.profile-badges {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
  margin-bottom: 4px;
}

.profile-dept {
  font-size: 12px;
  color: var(--text-secondary, #8a9bb0);
}

.profile-actions {
  margin-top: 14px;
  display: flex;
  gap: 8px;
}

/* ==================== 资料字段 ==================== */
.profile-field {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid var(--bg-tertiary, #1a2d45);
}

.profile-field:last-child {
  border-bottom: none;
}

.profile-label {
  font-size: 13px;
  color: var(--text-secondary, #8a9bb0);
  flex-shrink: 0;
}

.profile-value {
  font-size: 14px;
  color: var(--text-primary, #e8ecf1);
  text-align: right;
  word-break: break-word;
}

.profile-value.text-normal {
  color: var(--radar-green, #00d26a);
}

.profile-value.text-warning {
  color: var(--amber, #ffaa00);
}

/* ==================== 编辑表单 ==================== */
.profile-edit-avatar-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 8px 0;
}

.profile-edit-avatar {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  border: 2px solid var(--border-color, #1e3a5f);
  background: var(--bg-tertiary, #1a2d45);
}

.profile-avatar-options {
  display: flex;
  gap: 16px;
  margin-top: 8px;
}
.profile-avatar-opt {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}
.profile-avatar-opt-img {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 2px solid var(--border-color, #1e3a5f);
}
.profile-avatar-opt-label {
  font-size: 11px;
  color: var(--text-secondary);
}

.profile-edit-actions {
  margin-top: 16px;
}

/* ==================== 性别选择器 ==================== */
input.input, picker .input {
  width: 100%;
  height: 44px;
  padding: 0 12px;
  border: 1px solid var(--border-color, #1e3a5f);
  border-radius: 6px;
  font-size: 14px;
  box-sizing: border-box;
  background: var(--bg-primary, #0a1628);
  color: var(--text-primary, #e8ecf1);
  display: flex;
  align-items: center;
}

/* ==================== 提醒卡片 ==================== */
.reminder-summary-card {
  background: rgba(255, 77, 79, 0.04);
  border-color: rgba(255, 77, 79, 0.18);
}
.reminder-list {
  max-height: 300px;
  overflow-y: auto;
}
.reminder-item {
  padding: 10px 0;
  border-bottom: 1px solid var(--bg-tertiary, #1a2d45);
}
.reminder-item:last-child {
  border-bottom: none;
}
.reminder-item-header {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}
.expiry-tag {
  display: inline-block;
  font-size: 11px;
  padding: 1px 8px;
  border-radius: 3px;
  line-height: 1.6;
  font-weight: 500;
  white-space: nowrap;
}
.expiry-warning {
  color: #ffaa00;
  background: rgba(255, 170, 0, 0.1);
  border: 1px solid rgba(255, 170, 0, 0.3);
}
.expiry-expired {
  color: #ff4d4f;
  background: rgba(255, 77, 79, 0.1);
  border: 1px solid rgba(255, 77, 79, 0.3);
}

/* ==================== 标签 ==================== */
.profile-tag-blue {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 12px;
  color: var(--accent-blue);
  background: rgba(59, 130, 246, 0.1);
  border: 1px solid rgba(59, 130, 246, 0.3);
  padding: 2px 8px;
  border-radius: 4px;
}

/* ==================== 首次登录提示横幅 ==================== */
.profile-firstlogin-banner {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px 14px;
  margin-bottom: 12px;
  background: rgba(30, 58, 95, 0.6);
  border: 1px solid var(--border-color, #1e3a5f);
  border-radius: 8px;
}

.profile-firstlogin-icon {
  font-size: 18px;
  flex-shrink: 0;
}

.profile-firstlogin-text {
  font-size: 13px;
  color: var(--text-secondary, #8a9bb0);
  line-height: 1.5;
}

/* ==================== 管理操作 ==================== */
.profile-manage-actions {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}
